<script>
  import { setupPickers } from '../scripts/pickers';

  // Pré-remplissage depuis le contexte de recherche (accueil / liste véhicules)
  const urlParams = new URLSearchParams(window.location.search);
  const paramToInput: Record<string, string> = {
    'pickup': 'res-pickup',
    'dropoff': 'res-dropoff',
    'date-start': 'res-date-start',
    'time-start': 'res-time-start',
    'date-end': 'res-date-end',
    'time-end': 'res-time-end',
  };
  Object.entries(paramToInput).forEach(([qp, id]) => {
    const v = urlParams.get(qp);
    if (v) {
      const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = v;
    }
  });

  setupPickers('res-app');

  type SimpleVehicle = { id: string; name: string; image: string; priceLow: number; priceHigh: number; category: string; categorySlug: string; seats: number; transmission: string; doors: number };
  type SimpleExtra = { id: string; label: string; price: number; per: string };
  type SimpleAgence = { id: string; name: string };
  type SimpleProtection = { id: string; name: string; price: number };

  const vehiclesData: SimpleVehicle[] = JSON.parse(document.getElementById('res-vehicles-data')?.textContent || '[]');
  const extrasData: SimpleExtra[] = JSON.parse(document.getElementById('res-extras-data')?.textContent || '[]');
  const agencesData: SimpleAgence[] = JSON.parse(document.getElementById('res-agences-data')?.textContent || '[]');
  const protectionsData: SimpleProtection[] = JSON.parse(document.getElementById('res-protections-data')?.textContent || '[]');

  // Libellés des agences pré-sélectionnées
  function syncLocLabel(inputId: string): void {
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    const label = document.querySelector(`#res-app [data-pk-input="${inputId}"] [data-pk-label]`);
    const ag = agencesData.find((a) => a.id === input?.value);
    if (label && ag) label.textContent = ag.name;
  }
  syncLocLabel('res-pickup');
  syncLocLabel('res-dropoff');

  let currentStep = 1;
  const totalSteps = 5;
  let selectedVehicleId: string | null = urlParams.get('vehicule');
  let selectedProtection = 'essentielle';
  let vehFilter = 'all';

  const stepEls = Array.from(document.querySelectorAll('.res-step')) as HTMLElement[];
  const stepperItems = Array.from(document.querySelectorAll('.res-stepper-item')) as HTMLElement[];
  const stepperFill = document.getElementById('res-stepper-fill');
  const prevBtn = document.getElementById('res-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('res-next') as HTMLButtonElement | null;
  const resMain = document.querySelector('.res-main');
  const successEl = document.getElementById('res-success');

  const fmtEUR = (n: number) =>
    (Number.isInteger(n) ? String(n) : n.toFixed(2).replace('.', ',')) + '€';

  function isHighSeason(d: Date): boolean {
    const month = d.getMonth() + 1;
    const day = d.getDate();
    if (month === 12) return day >= 20;
    if (month < 4) return true;
    if (month === 4) return day <= 20;
    return false;
  }

  function getDuration(): number {
    const ds = (document.getElementById('res-date-start') as HTMLInputElement | null)?.value;
    const de = (document.getElementById('res-date-end') as HTMLInputElement | null)?.value;
    if (!ds || !de) return 1;
    const diff = Math.round((new Date(de).getTime() - new Date(ds).getTime()) / 86400000);
    return diff > 0 ? diff : 1;
  }

  function vehicleGross(v: SimpleVehicle, duration: number): number {
    const ds = (document.getElementById('res-date-start') as HTMLInputElement | null)?.value;
    if (!ds) return v.priceLow * duration;
    let total = 0;
    const start = new Date(ds + 'T12:00:00');
    for (let i = 0; i < duration; i++) {
      const d = new Date(start);
      d.setDate(start.getDate() + i);
      total += isHighSeason(d) ? v.priceHigh : v.priceLow;
    }
    return total;
  }

  /* ── Étape 2 : grille véhicules + filtres ── */

  function renderVehicleGrid() {
    const grid = document.getElementById('res-veh-grid');
    if (!grid) return;
    const duration = getDuration();
    const list = vehiclesData.filter((v) => vehFilter === 'all' || v.categorySlug === vehFilter);

    grid.innerHTML = list.map((v) => {
      const gross = vehicleGross(v, duration);
      const discounted = duration >= 7 ? Math.round(gross * 0.8 * 100) / 100 : gross;
      const perDay = Math.round((discounted / duration) * 100) / 100;
      const dealLine = duration >= 7
        ? `<div class="res-veh-card-deal">soit ${fmtEUR(perDay)}/jour · −20% appliqué</div>`
        : `<div class="res-veh-card-deal">soit ${fmtEUR(perDay)}/jour</div>`;
      const priceBlock = duration >= 7
        ? `<s>${fmtEUR(gross)}</s>${fmtEUR(discounted)}<small>/${duration} j</small>`
        : `${fmtEUR(discounted)}<small>/${duration} j</small>`;
      return `
        <div class="res-veh-card ${v.id === selectedVehicleId ? 'is-selected' : ''}" data-veh-id="${v.id}">
          <img src="${v.image}" alt="${v.name}" />
          <div class="res-veh-card-body">
            <div class="res-veh-card-name">${v.name}</div>
            <div class="res-veh-card-meta">${v.category} · ${v.seats} places · ${v.transmission} · ${v.doors} portes</div>
            ${dealLine}
          </div>
          <div class="res-veh-card-price">${priceBlock}</div>
          <div class="res-veh-card-check">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
        </div>
      `;
    }).join('');

    grid.querySelectorAll('.res-veh-card').forEach((card) => {
      card.addEventListener('click', () => {
        selectedVehicleId = card.getAttribute('data-veh-id');
        grid.querySelectorAll('.res-veh-card').forEach((c) => c.classList.remove('is-selected'));
        card.classList.add('is-selected');
        updateSummary();
      });
    });
  }

  document.querySelectorAll('.res-veh-filter').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.res-veh-filter').forEach((b) => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');
      vehFilter = btn.getAttribute('data-filter') || 'all';
      renderVehicleGrid();
    });
  });

  /* ── Étape 3 : protections ── */

  document.querySelectorAll('.res-protection').forEach((card) => {
    card.addEventListener('click', () => {
      selectedProtection = card.getAttribute('data-protection') || 'essentielle';
      document.querySelectorAll('.res-protection').forEach((c) => c.classList.remove('is-selected'));
      card.classList.add('is-selected');
      updateSummary();
    });
  });

  /* ── Récapitulatif ── */

  function computeTotals() {
    const duration = getDuration();
    const vehicle = vehiclesData.find((v) => v.id === selectedVehicleId) || null;
    const gross = vehicle ? vehicleGross(vehicle, duration) : 0;
    const discount = duration >= 7 && gross > 0 ? Math.round(gross * 0.2 * 100) / 100 : 0;
    const protection = protectionsData.find((p) => p.id === selectedProtection) || protectionsData[0];
    const protectionTotal = protection ? protection.price * duration : 0;

    let extrasTotal = 0;
    const chosenExtras: { label: string; total: number }[] = [];
    extrasData.forEach((e) => {
      const input = document.querySelector(`[data-extra-input="${e.id}"]`) as HTMLInputElement | null;
      if (input?.checked) {
        const lineTotal = e.per === 'jour' ? e.price * duration : e.price;
        extrasTotal += lineTotal;
        chosenExtras.push({ label: e.label, total: lineTotal });
      }
    });

    const grand = Math.round((gross - discount + protectionTotal + extrasTotal) * 100) / 100;
    return { duration, vehicle, gross, discount, protection, protectionTotal, chosenExtras, extrasTotal, grand };
  }

  function agenceLine(): string {
    const puVal = (document.getElementById('res-pickup') as HTMLInputElement | null)?.value;
    const doInput = document.getElementById('res-dropoff') as HTMLInputElement | null;
    const doVal = doInput && !doInput.disabled && doInput.value ? doInput.value : puVal;
    const puName = agencesData.find((a) => a.id === puVal)?.name || '—';
    const doName = agencesData.find((a) => a.id === doVal)?.name || puName;
    return doName !== puName ? `${puName} → ${doName}` : puName;
  }

  function updateSummary() {
    const t = computeTotals();

    const durationEl = document.getElementById('res-summary-duration');
    if (durationEl) {
      const timeStart = (document.getElementById('res-time-start') as HTMLSelectElement | null)?.value;
      const timeEnd = (document.getElementById('res-time-end') as HTMLSelectElement | null)?.value;
      const times = timeStart && timeEnd ? ` · ${timeStart} → ${timeEnd}` : '';
      durationEl.textContent = `${t.duration} jour${t.duration > 1 ? 's' : ''}${times}`;
    }

    const agenceEl = document.getElementById('res-summary-agence');
    if (agenceEl) agenceEl.textContent = agenceLine();

    const vehContainer = document.getElementById('res-summary-vehicle');
    if (t.vehicle && vehContainer) {
      vehContainer.innerHTML = `
        <div class="res-summary-vehicle-selected">
          <img src="${t.vehicle.image}" alt="${t.vehicle.name}" />
          <div>
            <div class="res-summary-vehicle-selected-name">${t.vehicle.name}</div>
            <div class="res-summary-vehicle-selected-meta">${t.vehicle.category} · ${t.vehicle.transmission}</div>
          </div>
        </div>
      `;
    } else if (vehContainer) {
      vehContainer.innerHTML = `
        <div class="res-summary-vehicle-placeholder">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 3H5L3 10v9h2v2h2v-2h10v2h2v-2h2v-9z"/><circle cx="7" cy="15" r="1.5"/><circle cx="17" cy="15" r="1.5"/></svg>
          <span>Aucun véhicule sélectionné</span>
        </div>
      `;
    }

    const vehPriceEl = document.getElementById('res-summary-veh-price');
    if (vehPriceEl) vehPriceEl.textContent = fmtEUR(t.gross);

    const discountRow = document.getElementById('res-summary-discount-row');
    const discountEl = document.getElementById('res-summary-discount');
    if (discountRow) discountRow.hidden = t.discount === 0;
    if (discountEl) discountEl.textContent = t.discount > 0 ? `−${fmtEUR(t.discount)}` : '0€';

    const protNameEl = document.getElementById('res-summary-protection-name');
    const protEl = document.getElementById('res-summary-protection');
    if (protNameEl && t.protection) protNameEl.textContent = t.protection.name;
    if (protEl && t.protection) protEl.textContent = t.protection.price === 0 ? 'Incluse' : fmtEUR(t.protectionTotal);

    const extrasContainer = document.getElementById('res-summary-extras');
    if (extrasContainer) {
      extrasContainer.innerHTML = t.chosenExtras
        .map((e) => `<div class="res-summary-row"><span>${e.label}</span><span>${fmtEUR(e.total)}</span></div>`)
        .join('');
    }

    const totalEl = document.getElementById('res-summary-total');
    if (totalEl) {
      totalEl.textContent = fmtEUR(t.grand);
      totalEl.animate([{ transform: 'scale(1.08)' }, { transform: 'scale(1)' }], { duration: 300, easing: 'ease-out' });
    }
  }

  /* ── Étape 5 : récapitulatif détaillé ── */

  function fmtDateFR(iso: string): string {
    if (!iso) return '—';
    return new Date(iso + 'T00:00:00').toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
  }

  function buildRecap() {
    const recap = document.getElementById('res-recap');
    if (!recap) return;
    const t = computeTotals();
    const ds = (document.getElementById('res-date-start') as HTMLInputElement | null)?.value || '';
    const de = (document.getElementById('res-date-end') as HTMLInputElement | null)?.value || '';
    const ts = (document.getElementById('res-time-start') as HTMLSelectElement | null)?.value || '';
    const te = (document.getElementById('res-time-end') as HTMLSelectElement | null)?.value || '';

    const vehBlock = t.vehicle
      ? `<div class="res-recap-veh">
           <img src="${t.vehicle.image}" alt="${t.vehicle.name}" />
           <div>
             <strong>${t.vehicle.name}</strong>
             <small>${t.vehicle.category} · ${t.vehicle.seats} places · ${t.vehicle.transmission}</small>
           </div>
         </div>`
      : '';

    const extraRows = t.chosenExtras
      .map((e) => `<div class="res-recap-row"><span>${e.label}</span><span>${fmtEUR(e.total)}</span></div>`)
      .join('');

    recap.innerHTML = `
      ${vehBlock}
      <div class="res-recap-row"><span>Départ</span><span>${fmtDateFR(ds)} à ${ts}</span></div>
      <div class="res-recap-row"><span>Retour</span><span>${fmtDateFR(de)} à ${te}</span></div>
      <div class="res-recap-row"><span>Agence</span><span>${agenceLine()}</span></div>
      <div class="res-recap-row"><span>Véhicule (${t.duration} j)</span><span>${fmtEUR(t.gross)}</span></div>
      ${t.discount > 0 ? `<div class="res-recap-row"><span>Remise −20% (7 j et +)</span><span>−${fmtEUR(t.discount)}</span></div>` : ''}
      <div class="res-recap-row"><span>Protection ${t.protection?.name || ''}</span><span>${t.protection && t.protection.price > 0 ? fmtEUR(t.protectionTotal) : 'Incluse'}</span></div>
      ${extraRows}
      <div class="res-recap-total"><span>Total</span><span>${fmtEUR(t.grand)}</span></div>
    `;
  }

  /* ── Navigation ── */

  function goToStep(step: number) {
    currentStep = Math.max(1, Math.min(totalSteps, step));

    stepEls.forEach((el) => el.classList.toggle('is-active', Number(el.getAttribute('data-step')) === currentStep));
    stepperItems.forEach((item) => {
      const idx = Number(item.getAttribute('data-step-indicator'));
      item.classList.toggle('is-active', idx === currentStep);
      item.classList.toggle('is-done', idx < currentStep);
    });
    if (stepperFill) stepperFill.style.width = `${((currentStep - 1) / (totalSteps - 1)) * 100}%`;

    if (prevBtn) prevBtn.hidden = currentStep === 1;
    if (nextBtn) {
      nextBtn.innerHTML = currentStep === totalSteps
        ? 'Confirmer la réservation <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>'
        : 'Continuer <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
    }

    if (currentStep === 2) renderVehicleGrid();
    if (currentStep === totalSteps) buildRecap();
    updateSummary();
    resMain?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function spawnConfetti() {
    const container = document.querySelector('.res-confetti');
    if (!container) return;
    const colors = ['#E31837', '#FF6B35', '#00A98F', '#E8A413'];
    for (let i = 0; i < 40; i++) {
      const piece = document.createElement('span');
      piece.style.left = `${Math.random() * 100}%`;
      piece.style.background = colors[i % colors.length];
      piece.style.animationDelay = `${Math.random() * 0.5}s`;
      piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
      container.appendChild(piece);
    }
  }

  nextBtn?.addEventListener('click', () => {
    if (currentStep === 1) {
      const endDate = document.getElementById('res-date-end') as HTMLInputElement | null;
      if (endDate && !endDate.value) {
        document.querySelector<HTMLElement>('#res-app [data-pk-date="res-date-end"]')?.click();
        return;
      }
    }
    if (currentStep === 2 && !selectedVehicleId) {
      const grid = document.getElementById('res-veh-grid');
      grid?.animate([{ transform: 'translateX(-6px)' }, { transform: 'translateX(6px)' }, { transform: 'translateX(0)' }], { duration: 300 });
      return;
    }
    if (currentStep === totalSteps) {
      const termsCheck = document.getElementById('res-terms-check') as HTMLInputElement | null;
      if (!termsCheck?.checked) {
        termsCheck?.parentElement?.animate([{ transform: 'translateX(-4px)' }, { transform: 'translateX(4px)' }, { transform: 'translateX(0)' }], { duration: 250 });
        return;
      }
      const ref = 'ADV-' + Math.random().toString(36).slice(2, 8).toUpperCase();
      const refEl = document.getElementById('res-ref');
      if (refEl) refEl.textContent = ref;
      if (resMain) (resMain.querySelector('.res-step.is-active') as HTMLElement).style.display = 'none';
      document.querySelector('.res-stepper')?.setAttribute('hidden', 'true');
      document.querySelector('.res-nav')?.setAttribute('hidden', 'true');
      document.querySelector('.res-summary')?.setAttribute('hidden', 'true');
      if (successEl) {
        successEl.hidden = false;
        spawnConfetti();
      }
      return;
    }
    goToStep(currentStep + 1);
  });

  prevBtn?.addEventListener('click', () => goToStep(currentStep - 1));

  document.querySelectorAll('.res-extra-checkbox').forEach((input) => {
    input.addEventListener('change', updateSummary);
  });

  ['res-date-start', 'res-date-end', 'res-time-start', 'res-time-end', 'res-pickup', 'res-dropoff'].forEach((id) => {
    document.getElementById(id)?.addEventListener('change', () => {
      if (currentStep === 2) renderVehicleGrid();
      updateSummary();
    });
  });

  /* ── Lieu de retour identique / différent ── */

  const resSwitch = document.getElementById('res-same-location');
  const dropoffField = document.getElementById('res-dropoff-field');
  const dropoffInput = document.getElementById('res-dropoff') as HTMLInputElement | null;

  // Le champ retour est visible par défaut ; on le synchronise si identique.
  function toggleSameLocation() {
    dropoffField?.classList.toggle('is-hidden');
    if (dropoffInput) dropoffInput.disabled = dropoffField?.classList.contains('is-hidden') ?? false;
    updateSummary();
  }
  resSwitch?.addEventListener('click', toggleSameLocation);

  /* ── Démarrage : entonnoir rapide ── */

  const pParamPickup = urlParams.get('pickup');
  const pParamDrop = urlParams.get('dropoff');
  if (pParamPickup && pParamDrop && pParamDrop === pParamPickup && dropoffInput) {
    // même agence : rien à faire, le champ reste visible et synchronisé
  }

  const hasDatesFromSearch = Boolean(urlParams.get('date-start') && urlParams.get('date-end'));
  let initialStep = 1;
  if (hasDatesFromSearch && selectedVehicleId) initialStep = 3;
  else if (hasDatesFromSearch) initialStep = 2;
  renderVehicleGrid();
  goToStep(initialStep);
</script>

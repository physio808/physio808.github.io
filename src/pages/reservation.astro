    gap: 14px;
    margin-bottom: 18px;
  }

  .rv-veh img {
    width: 96px;
    height: 64px;
    object-fit: contain;
    border-radius: 10px;
    background: radial-gradient(ellipse 90% 75% at 50% 70%, #E4E7EC 0%, #C2C7CF 100%);
    padding: 4px;
  }

  .rv-veh-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.02rem;
    color: var(--color-ink);
  }

  .rv-veh-meta {
    font-size: 0.78rem;
    color: var(--color-text-subtle);
  }

  .rv-section {
    padding: 14px 0;
  }

  .rv-section + .rv-section {
    border-top: 1px solid var(--color-border);
  }

  .rv-section-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.95rem;
    color: var(--color-ink);
    margin-bottom: 12px;
  }

  .rv-pay-tag {
    font-style: normal;
    color: var(--color-coral);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .rv-point {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .rv-point svg {
    color: var(--color-ink);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .rv-point small {
    display: block;
    font-size: 0.74rem;
    color: var(--color-text-subtle);
  }

  .rv-point strong {
    display: block;
    font-size: 0.92rem;
    color: var(--color-ink);
  }

  .rv-point span {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .rv-connector {
    width: 2px;
    height: 16px;
    background: var(--color-border-light);
    margin: 4px 0 4px 11px;
  }

  .rv-check {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--color-ink);
    padding: 4px 0;
  }

  .rv-check-left {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    line-height: 1.4;
  }

  .rv-check-left svg {
    color: #079455;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .rv-check > svg {
    color: #C9CDD4;
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* Lignes du récap dans le popover (injecté) — déjà couvert par .res-pop-row */
</style>

<script>
  import { setupPickers } from '../scripts/pickers';

  /* ── Pré-remplissage depuis le contexte de recherche (accueil / liste véhicules) ── */
  const urlParams = new URLSearchParams(window.location.search);
  const paramToInput: Record<string, string> = {
    'pickup': 'res-pickup',
    'dropoff': 'res-dropoff',
    'date-start': 'res-date-start',
    'time-start': 'res-time-start',
    'date-end': 'res-date-end',
    'time-end': 'res-time-end',
  };
  Object.entries(paramToInput).forEach(([qp, id]) => {
    const v = urlParams.get(qp);
    if (v) {
      const el = document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null;
      if (el) el.value = v;
    }
  });

  setupPickers('res-app');

  type SimpleVehicle = { id: string; name: string; image: string; priceLow: number; priceHigh: number; category: string; categorySlug: string; seats: number; bags: number; transmission: string; doors: number };
  type SimpleExtra = { id: string; label: string; price: number; per: string; stepper: boolean; max: number };
  type SimpleAgence = { id: string; name: string };
  type SimpleProtection = { id: string; name: string; price: number };

  const vehiclesData: SimpleVehicle[] = JSON.parse(document.getElementById('res-vehicles-data')?.textContent || '[]');
  const extrasData: SimpleExtra[] = JSON.parse(document.getElementById('res-extras-data')?.textContent || '[]');
  const agencesData: SimpleAgence[] = JSON.parse(document.getElementById('res-agences-data')?.textContent || '[]');
  const protectionsData: SimpleProtection[] = JSON.parse(document.getElementById('res-protections-data')?.textContent || '[]');
  const badgesData: Record<string, string> = JSON.parse(document.getElementById('res-badges-data')?.textContent || '{}');
  const stepTitles: Record<string, string> = JSON.parse(document.getElementById('res-step-titles')?.textContent || '{}');

  const FLEX_PRICE_PER_DAY = 4; // Option « Restez flexible » (+4€/jour, façon Sixt)

  function syncLocLabel(inputId: string): void {
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    const label = document.querySelector(`#res-app [data-pk-input="${inputId}"] [data-pk-label]`);
    const ag = agencesData.find((a) => a.id === input?.value);
    if (label && ag) label.textContent = ag.name;
  }
  syncLocLabel('res-pickup');
  syncLocLabel('res-dropoff');

  /* ── État ── */
  let currentStep = 1;
  const totalSteps = 5;
  let selectedVehicleId: string | null = urlParams.get('vehicule');
  let selectedProtection = 'essentielle';
  let vehFilter = 'all';
  let sortMode = 'reco';
  let paymentOption: 'best' | 'flex' = 'best';
  const extraQty: Record<string, number> = {};
  extrasData.forEach((e) => { extraQty[e.id] = 0; });

  const stepEls = Array.from(document.querySelectorAll('.res-step')) as HTMLElement[];
  const barTitle = document.getElementById('res-bar-title');
  const backBtn = document.getElementById('res-back') as HTMLButtonElement | null;
  const nextTopBtn = document.getElementById('res-next-top') as HTMLButtonElement | null;
  const resBar = document.getElementById('res-bar');
  const successEl = document.getElementById('res-success');

  const fmtEUR = (n: number) =>
    (Number.isInteger(n) ? String(n) : n.toFixed(2).replace('.', ',')) + '€';

  function isHighSeason(d: Date): boolean {
    const month = d.getMonth() + 1;
    const day = d.getDate();
    if (month === 12) return day >= 20;
    if (month < 4) return true;
    if (month === 4) return day <= 20;
    return false;
  }

  function getDuration(): number {
    const ds = (document.getElementById('res-date-start') as HTMLInputElement | null)?.value;
    const de = (document.getElementById('res-date-end') as HTMLInputElement | null)?.value;
    if (!ds || !de) return 1;
    const diff = Math.round((new Date(de).getTime() - new Date(ds).getTime()) / 86400000);
    return diff > 0 ? diff : 1;
  }

  function vehicleGross(v: SimpleVehicle, duration: number): number {
    const ds = (document.getElementById('res-date-start') as HTMLInputElement | null)?.value;
    if (!ds) return v.priceLow * duration;
    let total = 0;
    const start = new Date(ds + 'T12:00:00');
    for (let i = 0; i < duration; i++) {
      const d = new Date(start);
      d.setDate(start.getDate() + i);
      total += isHighSeason(d) ? v.priceHigh : v.priceLow;
    }
    return total;
  }

  function agenceLine(): string {
    const puVal = (document.getElementById('res-pickup') as HTMLInputElement | null)?.value;
    const doInput = document.getElementById('res-dropoff') as HTMLInputElement | null;
    const sameChecked = (document.getElementById('res-same-location') as HTMLInputElement | null)?.checked;
    const doVal = sameChecked && doInput ? doInput.value : puVal;
    const puName = agencesData.find((a) => a.id === puVal)?.name || '—';
    const doName = agencesData.find((a) => a.id === doVal)?.name || puName;
    return doName !== puName ? `${puName} → ${doName}` : puName;
  }

  /* ── Totaux ── */
  function computeTotals() {
    const duration = getDuration();
    const vehicle = vehiclesData.find((v) => v.id === selectedVehicleId) || null;
    const gross = vehicle ? vehicleGross(vehicle, duration) : 0;
    const discount = duration >= 7 && gross > 0 ? Math.round(gross * 0.2 * 100) / 100 : 0;
    const protection = protectionsData.find((p) => p.id === selectedProtection) || protectionsData[0];
    const protectionTotal = protection ? protection.price * duration : 0;
    const flexTotal = paymentOption === 'flex' ? FLEX_PRICE_PER_DAY * duration : 0;

    let extrasTotal = 0;
    const chosenExtras: { label: string; total: number }[] = [];
    extrasData.forEach((e) => {
      const qty = extraQty[e.id] || 0;
      if (qty > 0) {
        const lineTotal = e.per === 'jour' ? e.price * qty * duration : e.price * qty;
        extrasTotal += lineTotal;
        chosenExtras.push({ label: qty > 1 ? `${qty} × ${e.label}` : e.label, total: lineTotal });
      }
    });

    const grand = Math.round((gross - discount + protectionTotal + extrasTotal + flexTotal) * 100) / 100;
    return { duration, vehicle, gross, discount, protection, protectionTotal, chosenExtras, extrasTotal, flexTotal, grand };
  }

  function updateSummary() {
    const t = computeTotals();
    const totalEl = document.getElementById('res-bar-total');
    if (totalEl) {
      totalEl.textContent = fmtEUR(t.grand);
      totalEl.animate([{ transform: 'scale(1.06)' }, { transform: 'scale(1)' }], { duration: 250, easing: 'ease-out' });
    }
  }

  /* ── Popover détail du prix ── */
  const pricePop = document.getElementById('res-price-pop');
  const priceDetailsBtn = document.getElementById('res-price-details');

  function fillPricePop() {
    const body = document.getElementById('res-price-pop-body');
    if (!body) return;
    const t = computeTotals();
    const rows: string[] = [];
    if (t.vehicle) rows.push(`<div class="res-pop-row"><span>Véhicule (${t.duration} jour${t.duration > 1 ? 's' : ''})</span><span>${fmtEUR(t.gross)}</span></div>`);
    if (t.discount > 0) rows.push(`<div class="res-pop-row is-discount"><span>Remise −20% (7 jours et +)</span><span>−${fmtEUR(t.discount)}</span></div>`);
    if (t.flexTotal > 0) rows.push(`<div class="res-pop-row"><span>Option Restez flexible</span><span>+${fmtEUR(t.flexTotal)}</span></div>`);
    if (t.protection) rows.push(`<div class="res-pop-row"><span>${t.protection.name}</span><span>${t.protection.price === 0 ? 'Incluse' : '+' + fmtEUR(t.protectionTotal)}</span></div>`);
    t.chosenExtras.forEach((e) => rows.push(`<div class="res-pop-row"><span>${e.label}</span><span>+${fmtEUR(e.total)}</span></div>`));
    rows.push(`<div class="res-pop-total"><span>Total</span><span>${fmtEUR(t.grand)}</span></div>`);
    body.innerHTML = rows.join('');
  }

  function togglePricePop(force?: boolean) {
    if (!pricePop) return;
    const show = force ?? pricePop.hidden;
    if (show) fillPricePop();
    pricePop.hidden = !show;
    priceDetailsBtn?.setAttribute('aria-expanded', show ? 'true' : 'false');
  }

  priceDetailsBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    togglePricePop();
  });
  document.getElementById('res-price-pop-close')?.addEventListener('click', () => togglePricePop(false));
  document.addEventListener('click', (e) => {
    if (pricePop && !pricePop.hidden && !(e.target as HTMLElement).closest('.res-price-pop') && !(e.target as HTMLElement).closest('#res-price-details')) {
      togglePricePop(false);
    }
  });

  /* ── Étape 2 : grille véhicules ── */
  function renderVehicleGrid() {
    const grid = document.getElementById('res-veh-grid');
    if (!grid) return;
    const duration = getDuration();
    let list = vehiclesData.filter((v) => vehFilter === 'all' || v.categorySlug === vehFilter);

    const priced = list.map((v) => {
      const gross = vehicleGross(v, duration);
      const discounted = duration >= 7 ? Math.round(gross * 0.8 * 100) / 100 : gross;
      const perDay = Math.round((discounted / duration) * 100) / 100;
      return { v, gross, discounted, perDay };
    });
    if (sortMode === 'price-asc') priced.sort((a, b) => a.perDay - b.perDay);
    if (sortMode === 'price-desc') priced.sort((a, b) => b.perDay - a.perDay);

    // Pré-sélection du véhicule recommandé : le total s'affiche dès l'arrivée (ancrage prix)
    if (!selectedVehicleId && priced.length > 0) {
      selectedVehicleId = priced[0].v.id;
    }

    grid.innerHTML = priced.map(({ v, discounted, perDay }) => {
      const badge = badgesData[v.id] ? `<span class="vc-badge">${badgesData[v.id]}</span>` : '';
      const deal = duration >= 7 ? '<span class="vc-deal">Offre exceptionnelle</span>' : '';
      return `
        <article class="vc ${v.id === selectedVehicleId ? 'is-selected' : ''}" data-veh-id="${v.id}" tabindex="0" role="button" aria-label="Choisir ${v.name}">
          <div class="vc-name">${v.name}</div>
          <div class="vc-sub">${v.category} · ${v.transmission}</div>
          <div class="vc-meta">
            <span class="vc-similar">Ou modèle similaire
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="11" x2="12" y2="16"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            </span>
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg> ${v.seats}</span>
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="7" width="16" height="13" rx="2"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/></svg> ${v.bags}</span>
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M19.1 4.9L17 7M7 17l-2.1 2.1"/></svg> ${v.transmission}</span>
          </div>
          <div class="vc-media">
            <img src="${v.image}" alt="${v.name}" loading="lazy" />
            ${badge}
          </div>
          ${deal}
          <div class="vc-incl">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            Kilométrage illimité disponible
          </div>
          <div class="vc-price">
            <strong>${fmtEUR(perDay)} <small>/jour</small></strong>
            <span>${fmtEUR(discounted)} total</span>
          </div>
          <div class="vc-foot"><strong>ADVENTURA</strong> −20% dès 7 jours de location, appliqué automatiquement</div>
        </article>
      `;
    }).join('');

    grid.querySelectorAll('.vc').forEach((card) => {
      const select = () => {
        const id = card.getAttribute('data-veh-id');
        selectedVehicleId = id;
        grid.querySelectorAll('.vc').forEach((c) => c.classList.remove('is-selected'));
        card.classList.add('is-selected');
        updateSummary();
        openVehPanel(id);
      };
      card.addEventListener('click', select);
      card.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') select();
      });
    });
  }

  document.querySelectorAll('.res-filter').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.res-filter').forEach((b) => {
        b.classList.toggle('is-active', b === btn);
        b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
      });
      vehFilter = btn.getAttribute('data-filter') || 'all';
      renderVehicleGrid();
    });
  });

  document.getElementById('res-sort')?.addEventListener('change', (e) => {
    sortMode = (e.target as HTMLSelectElement).value;
    renderVehicleGrid();
  });

  /* ── Panneau détail véhicule ── */
  const vehPanel = document.getElementById('veh-panel');

  function openVehPanel(id: string | null) {
    const v = vehiclesData.find((x) => x.id === id);
    if (!v || !vehPanel) return;
    refreshVehPanelPrice(v);

    (document.getElementById('veh-panel-img') as HTMLImageElement).src = v.image;
    (document.getElementById('veh-panel-img') as HTMLImageElement).alt = v.name;
    document.getElementById('veh-panel-title')!.textContent = v.name;
    document.getElementById('veh-panel-sub')!.textContent = `${v.category} · ${v.transmission}`;
    document.getElementById('veh-panel-specs')!.innerHTML = [
      `${v.seats} Sièges`,
      `${v.bags} Valise(s)`,
      '1 Bagage(s) à main',
      v.transmission,
      `${v.doors} Portes`,
    ].map((s) => `<li>${s}</li>`).join('');

    vehPanel.hidden = false;
    document.body.style.overflow = 'hidden';
  }

  function refreshVehPanelPrice(v: SimpleVehicle) {
    const duration = getDuration();
    const gross = vehicleGross(v, duration);
    const discounted = duration >= 7 ? Math.round(gross * 0.8 * 100) / 100 : gross;
    const flex = paymentOption === 'flex' ? FLEX_PRICE_PER_DAY * duration : 0;
    const total = Math.round((discounted + flex) * 100) / 100;
    const perDay = Math.round((total / duration) * 100) / 100;
    document.getElementById('veh-panel-price')!.innerHTML =
      `${fmtEUR(perDay)} <small>/jour</small> <small>· ${fmtEUR(total)} total</small>`;
  }

  function closeVehPanel() {
    if (vehPanel) vehPanel.hidden = true;
    document.body.style.overflow = '';
  }

  document.getElementById('veh-panel-close')?.addEventListener('click', closeVehPanel);
  vehPanel?.addEventListener('click', (e) => {
    if (e.target === vehPanel) closeVehPanel();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && vehPanel && !vehPanel.hidden) closeVehPanel();
  });
  document.getElementById('veh-panel-next')?.addEventListener('click', () => {
    closeVehPanel();
    goToStep(3);
  });
  document.getElementById('veh-panel-details')?.addEventListener('click', () => {
    closeVehPanel();
    togglePricePop(true);
  });

  // Options de paiement (Meilleur prix / Restez flexible)
  document.querySelectorAll('.veh-pay[data-pay]').forEach((opt) => {
    opt.addEventListener('click', () => {
      paymentOption = (opt.getAttribute('data-pay') as 'best' | 'flex') || 'best';
      document.querySelectorAll('.veh-pay[data-pay]').forEach((o) => o.classList.toggle('is-selected', o === opt));
      const radio = opt.querySelector('input[type="radio"]') as HTMLInputElement | null;
      if (radio) radio.checked = true;
      const v = vehiclesData.find((x) => x.id === selectedVehicleId);
      if (v && vehPanel && !vehPanel.hidden) refreshVehPanelPrice(v);
      updateSummary();
      if (currentStep === 4) renderApercu();
      if (currentStep === 5) renderReview();
    });
  });

  /* ── Étape 3 : protections ── */
  document.querySelectorAll('.res-protection').forEach((card) => {
    const select = () => {
      selectedProtection = card.getAttribute('data-protection') || 'essentielle';
      document.querySelectorAll('.res-protection').forEach((c) => c.classList.remove('is-selected'));
      card.classList.add('is-selected');
      updateSummary();
    };
    card.addEventListener('click', select);
    card.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Enter') select();
    });
  });

  /* ── Étape 4 : options (toggles, steppers, détails) ── */
  document.querySelectorAll('[data-extra-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-extra-toggle')!;
      const on = btn.getAttribute('aria-checked') === 'true';
      btn.setAttribute('aria-checked', on ? 'false' : 'true');
      extraQty[id] = on ? 0 : 1;
      btn.closest('.res-extra')?.classList.toggle('is-on', !on);
      updateSummary();
      renderApercu();
    });
  });

  document.querySelectorAll('[data-stepper-plus]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-stepper-plus')!;
      const extra = extrasData.find((e) => e.id === id);
      const max = extra?.max ?? 1;
      if (extraQty[id] < max) {
        extraQty[id]++;
        syncStepper(id);
        updateSummary();
        renderApercu();
      }
    });
  });

  document.querySelectorAll('[data-stepper-minus]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-stepper-minus')!;
      if (extraQty[id] > 0) {
        extraQty[id]--;
        syncStepper(id);
        updateSummary();
        renderApercu();
      }
    });
  });

  function syncStepper(id: string) {
    const count = document.querySelector(`[data-stepper-count="${id}"]`);
    if (count) count.textContent = String(extraQty[id]);
    const minus = document.querySelector(`[data-stepper-minus="${id}"]`) as HTMLButtonElement | null;
    const plus = document.querySelector(`[data-stepper-plus="${id}"]`) as HTMLButtonElement | null;
    const extra = extrasData.find((e) => e.id === id);
    if (minus) minus.disabled = extraQty[id] <= 0;
    if (plus) plus.disabled = extraQty[id] >= (extra?.max ?? 1);
    const row = document.querySelector(`[data-extra="${id}"]`);
    row?.classList.toggle('is-on', extraQty[id] > 0);
  }

  document.querySelectorAll('[data-extra-details]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-extra-details')!;
      const desc = document.getElementById(`extra-desc-${id}`);
      if (desc) desc.hidden = !desc.hidden;
    });
  });

  extrasData.forEach((e) => syncStepper(e.id));

  /* ── Étape 4 : aperçu de la réservation ── */
  const checkSvg = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><polyline points="20 6 9 17 4 12"/></svg>';
  const infoSvg = '<svg class="res-apercu-item-info" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="11" x2="12" y2="16"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>';

  function apercuItem(text: string): string {
    return `<li class="res-apercu-item"><span class="res-apercu-item-left">${checkSvg}<span>${text}</span></span>${infoSvg}</li>`;
  }

  function renderApercu() {
    const list = document.getElementById('res-apercu-list');
    if (!list) return;
    const t = computeTotals();
    const items: string[] = [
      'Assurance au tiers',
      'Assistance dépannage 24/7',
      'Kilométrage illimité inclus',
    ];
    t.chosenExtras.forEach((e) => items.push(e.label));
    items.push(paymentOption === 'best'
      ? 'Option de paiement : Meilleur prix - Payez maintenant, annulation et modification moyennant des frais.'
      : 'Option de paiement : Restez flexible - Annulation et modification gratuites avant la prise en charge.');
    list.innerHTML = items.map(apercuItem).join('');
  }

  /* ── Étape 5 : carte récapitulative ── */
  function fmtReviewDate(iso: string, time: string): string {
    if (!iso) return '—';
    const s = new Date(iso + 'T00:00:00').toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
    return time ? `${s} | ${time}` : s;
  }

  function renderReview() {
    const card = document.getElementById('res-review-card');
    if (!card) return;
    const t = computeTotals();
    const ds = (document.getElementById('res-date-start') as HTMLInputElement | null)?.value || '';
    const de = (document.getElementById('res-date-end') as HTMLInputElement | null)?.value || '';
    const ts = (document.getElementById('res-time-start') as HTMLSelectElement | null)?.value || '';
    const te = (document.getElementById('res-time-end') as HTMLSelectElement | null)?.value || '';
    const puVal = (document.getElementById('res-pickup') as HTMLInputElement | null)?.value;
    const sameChecked = (document.getElementById('res-same-location') as HTMLInputElement | null)?.checked;
    const doVal = sameChecked ? (document.getElementById('res-dropoff') as HTMLInputElement | null)?.value : puVal;
    const puName = agencesData.find((a) => a.id === puVal)?.name || '—';
    const doName = agencesData.find((a) => a.id === doVal)?.name || puName;

    const buildingSvg = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="3" width="16" height="18" rx="1"/><line x1="9" y1="21" x2="9" y2="17"/><line x1="15" y1="21" x2="15" y2="17"/><line x1="8" y1="7" x2="10" y2="7"/><line x1="14" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="10" y2="11"/><line x1="14" y1="11" x2="16" y2="11"/></svg>';
    const rvInfo = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="11" x2="12" y2="16"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>';
    const rvCheck = (text: string) => `<div class="rv-check"><span class="rv-check-left">${checkSvg}<span>${text}</span></span>${rvInfo}</div>`;

    card.innerHTML = `
      ${t.vehicle ? `
      <div class="rv-veh">
        <img src="${t.vehicle.image}" alt="${t.vehicle.name}" />
        <div>
          <div class="rv-veh-name">${t.vehicle.name}</div>
          <div class="rv-veh-meta">ou similaire | ${t.vehicle.category}</div>
        </div>
      </div>` : ''}
      <div class="rv-section">
        <div class="rv-section-title">Prise en charge et retour</div>
        <div class="rv-point">
          ${buildingSvg}
          <div>
            <small>Prise en charge</small>
            <strong>${puName}</strong>
            <span>${fmtReviewDate(ds, ts)}</span>
          </div>
        </div>
        <div class="rv-connector"></div>
        <div class="rv-point">
          ${buildingSvg}
          <div>
            <small>Retour</small>
            <strong>${doName}</strong>
            <span>${fmtReviewDate(de, te)}</span>
          </div>
        </div>
      </div>
      <div class="rv-section">
        <div class="rv-section-title">Options de paiement <em class="rv-pay-tag">${paymentOption === 'best' ? 'MEILLEUR PRIX' : 'FLEXIBLE'}</em></div>
        ${rvCheck(paymentOption === 'best' ? 'Meilleur tarif disponible' : 'Annulation et modification gratuites avant la prise en charge')}
      </div>
      <div class="rv-section">
        <div class="rv-section-title">Ce qui est inclus</div>
        ${rvCheck('Assurance au tiers')}
        ${rvCheck('Assistance dépannage 24/7')}
        ${rvCheck('Kilométrage illimité inclus')}
        ${t.protection && t.protection.price > 0 ? rvCheck(t.protection.name) : ''}
        ${t.chosenExtras.map((e) => rvCheck(e.label)).join('')}
      </div>
    `;
  }

  /* ── Navigation ── */
  function goToStep(step: number) {
    currentStep = Math.max(1, Math.min(totalSteps, step));

    stepEls.forEach((el) => el.classList.toggle('is-active', Number(el.getAttribute('data-step')) === currentStep));
    if (barTitle) barTitle.textContent = stepTitles[String(currentStep)] || '';
    if (backBtn) backBtn.hidden = currentStep === 1;
    if (nextTopBtn) nextTopBtn.textContent = currentStep === totalSteps ? 'Confirmer la réservation' : 'Continuer';

    if (currentStep === 2) renderVehicleGrid();
    if (currentStep === 4) renderApercu();
    if (currentStep === 5) renderReview();
    updateSummary();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function shake(el: Element | null) {
    el?.animate([{ transform: 'translateX(-6px)' }, { transform: 'translateX(6px)' }, { transform: 'translateX(0)' }], { duration: 300 });
  }

  function handleNext() {
    if (currentStep === 1) {
      const endDate = document.getElementById('res-date-end') as HTMLInputElement | null;
      if (endDate && !endDate.value) {
        document.querySelector<HTMLElement>('#res-app [data-pk-open="range"]')?.click();
        return;
      }
      goToStep(2);
      return;
    }
    if (currentStep === 2 && !selectedVehicleId) {
      shake(document.getElementById('res-veh-grid'));
      return;
    }
    if (currentStep === totalSteps) {
      const termsCheck = document.getElementById('res-terms-check') as HTMLInputElement | null;
      if (!termsCheck?.checked) {
        shake(termsCheck?.closest('.res-terms') || null);
        return;
      }
      const ref = 'ADV-' + Math.random().toString(36).slice(2, 8).toUpperCase();
      const refEl = document.getElementById('res-ref');
      if (refEl) refEl.textContent = ref;
      stepEls.forEach((el) => el.classList.remove('is-active'));
      if (resBar) resBar.style.display = 'none';
      if (successEl) {
        successEl.hidden = false;
        spawnConfetti();
      }
      window.scrollTo({ top: 0, behavior: 'smooth' });
      return;
    }
    goToStep(currentStep + 1);
  }

  nextTopBtn?.addEventListener('click', handleNext);
  backBtn?.addEventListener('click', () => goToStep(currentStep - 1));
  document.getElementById('res-go-2')?.addEventListener('click', handleNext);

  function spawnConfetti() {
    const container = document.querySelector('.res-confetti');
    if (!container) return;
    const colors = ['#E31837', '#FF6B35', '#00A98F', '#E8A413'];
    for (let i = 0; i < 40; i++) {
      const piece = document.createElement('span');
      piece.style.left = `${Math.random() * 100}%`;
      piece.style.background = colors[i % colors.length];
      piece.style.animationDelay = `${Math.random() * 0.5}s`;
      piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
      container.appendChild(piece);
    }
  }

  /* ── Lieu de retour différent ── */
  const resSwitch = document.getElementById('res-same-location') as HTMLInputElement | null;
  const dropoffField = document.getElementById('res-dropoff-field');
  resSwitch?.addEventListener('change', () => {
    dropoffField?.classList.toggle('is-hidden', !resSwitch.checked);
    updateSummary();
  });

  /* ── Recalculs sur changement de contexte ── */
  ['res-date-start', 'res-date-end', 'res-time-start', 'res-time-end', 'res-pickup', 'res-dropoff'].forEach((id) => {
    document.getElementById(id)?.addEventListener('change', () => {
      if (currentStep === 2) renderVehicleGrid();
      if (currentStep === 4) renderApercu();
      if (currentStep === 5) renderReview();
      updateSummary();
    });
  });

  /* ── Démarrage : entonnoir rapide ── */
  const hasDatesFromSearch = Boolean(urlParams.get('date-start') && urlParams.get('date-end'));
  let initialStep = 1;
  if (hasDatesFromSearch && selectedVehicleId) initialStep = 3;
  else if (hasDatesFromSearch) initialStep = 2;
  renderVehicleGrid();
  goToStep(initialStep);
</script>

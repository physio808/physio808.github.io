---
import BaseLayout from '../layouts/BaseLayout.astro';
import { agences, vehicles } from '../data/data';

const today = new Date().toISOString().split('T')[0];

const timeSlots: string[] = [];
for (let h = 7; h <= 19; h++) {
  timeSlots.push(`${String(h).padStart(2, '0')}:00`);
  if (h < 19) timeSlots.push(`${String(h).padStart(2, '0')}:30`);
}

// Lignes de garantie communes (ordre fixe), affichées avec ✓ / ✗ par formule
const protectionRows = [
  'Dommages : collision, rayures, chocs et vol',
  'Pneus, pare-brise, vitres',
  'Dommages intérieurs (ex : taches)',
  'Assistance dépannage : incidents courants, perte de clés...',
  'Protection conducteur et passagers',
];

const protections = [
  {
    id: 'essentielle',
    name: 'Aucune protection supplémentaire',
    price: 0,
    strike: null as number | null,
    remise: null as string | null,
    stars: 0,
    franchise: 'Franchise : jusqu\'à 800€',
    franchiseOk: false,
    covers: [false, false, false, true, false],
  },
  {
    id: 'basique',
    name: 'Protection Basique',
    price: 4,
    strike: 8,
    remise: null as string | null,
    stars: 1,
    franchise: 'Franchise réduite : 400€',
    franchiseOk: false,
    covers: [true, false, false, true, false],
  },
  {
    id: 'confort',
    name: 'Protection Intermédiaire',
    price: 8,
    strike: 16,
    remise: '- 50% de remise en ligne',
    stars: 2,
    franchise: 'Franchise : 150€',
    franchiseOk: false,
    covers: [true, true, false, true, true],
  },
  {
    id: 'serenite',
    name: 'Protection Complète',
    price: 12,
    strike: 24,
    remise: '- 50% de remise en ligne',
    stars: 3,
    franchise: 'Pas de franchise',
    franchiseOk: true,
    covers: [true, true, true, true, true],
  },
];

const extras = [
  { id: 'conducteur', label: 'Conducteur supplémentaire', desc: 'Second conducteur assuré au contrat, même conditions que le conducteur principal.', price: 6, per: 'jour', perLabel: '/ jour et conducteur', stepper: true, max: 3, icon: 'user' },
  { id: 'siege-bebe', label: 'Siège bébé (0-3 ans)', desc: 'Siège homologué, installé avant votre arrivée à l\'agence.', price: 4, per: 'jour', perLabel: '/ jour', stepper: false, max: 1, icon: 'baby' },
  { id: 'rehausseur', label: 'Rehausseur enfant', desc: 'Pour les enfants de 4 à 10 ans, obligatoire selon la taille.', price: 3, per: 'jour', perLabel: '/ jour', stepper: false, max: 1, icon: 'booster' },
  { id: 'gps', label: 'Système de navigation GPS', desc: 'Cartes de tout l\'archipel préchargées, fonctionne hors ligne.', price: 5, per: 'jour', perLabel: '/ jour', stepper: false, max: 1, icon: 'map' },
  { id: 'wifi', label: 'Wifi de poche 4G', desc: 'Internet illimité, jusqu\'à 5 appareils connectés.', price: 3, per: 'jour', perLabel: '/ jour', stepper: false, max: 1, icon: 'wifi' },
  { id: 'plein-prepaye', label: 'Service de plein/recharge', desc: 'Rendez le véhicule sans repasser à la pompe, nous nous occupons du plein.', price: 65, per: 'location', perLabel: '/ une fois', stepper: false, max: 1, icon: 'fuel' },
  { id: 'arrivee-nuit', label: 'Arrivée hors horaires', desc: 'Remise des clés entre 22h et 6h, sur présentation du numéro de vol.', price: 25, per: 'location', perLabel: '/ une fois', stepper: false, max: 1, icon: 'moon' },
];

const extraIcons: Record<string, string> = {
  user: '<circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/>',
  baby: '<circle cx="12" cy="6" r="3"/><path d="M6 21v-4a6 6 0 0 1 12 0v4"/>',
  booster: '<path d="M6 4h9l2 7h3v4h-2l-1 6H7L6 15H4v-4h3z"/>',
  map: '<path d="M9 20l-6-3V4l6 3 6-3 6 3v13l-6-3-6 3z"/><line x1="9" y1="7" x2="9" y2="20"/><line x1="15" y1="4" x2="15" y2="17"/>',
  wifi: '<path d="M5 12.5a11 11 0 0 1 14 0"/><path d="M8.5 16a6 6 0 0 1 7 0"/><circle cx="12" cy="19.5" r="1"/>',
  fuel: '<path d="M4 22V6a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v16"/><path d="M14 10h2a2 2 0 0 1 2 2v5a1.5 1.5 0 0 0 3 0V9l-3-3"/><line x1="2" y1="22" x2="16" y2="22"/><path d="M6 8h6"/>',
  moon: '<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>',
};

const vehiclesJson = JSON.stringify(
  vehicles.map((v) => ({ id: v.id, name: v.name, image: v.imageCutout || v.image, priceLow: v.priceLow, priceHigh: v.priceHigh, category: v.category, categorySlug: v.categorySlug, seats: v.seats, bags: v.bags, transmission: v.transmission, doors: v.doors }))
);
const extrasJson = JSON.stringify(extras.map((e) => ({ id: e.id, label: e.label, price: e.price, per: e.per, stepper: e.stepper, max: e.max })));
const agencesJson = JSON.stringify(agences.map((a) => ({ id: a.id, name: a.name })));
const protectionsJson = JSON.stringify(protections.map((p) => ({ id: p.id, name: p.name, price: p.price })));

// Badges façon Sixt sur les cartes véhicules
const cardBadges: Record<string, string> = {
  'suzuki-swift-gl-plus': 'MEILLEUR CHOIX',
  'kia-stonic': 'TRÈS DEMANDÉ',
  'fiat-500-lounge': 'MEILLEUR PRIX',
};
const badgesJson = JSON.stringify(cardBadges);

const stepTitles: Record<number, string> = {
  1: 'VOS DATES ET VOTRE AGENCE',
  2: 'QUELLE VOITURE VOULEZ-VOUS CONDUIRE ?',
  3: 'DE QUELLE PROTECTION AVEZ-VOUS BESOIN ?',
  4: 'DE QUELLES OPTIONS AVEZ-VOUS BESOIN ?',
  5: 'REVOIR VOTRE RÉSERVATION',
};
const stepTitlesJson = JSON.stringify(stepTitles);
---

<BaseLayout
  title="Réservation"
  description="Réservez votre voiture en Guadeloupe en quelques minutes : véhicule, protection, options et confirmation immédiate. Kilométrage illimité inclus."
>
  <section class="res" id="res-app">
    <!-- Barre de tunnel façon Sixt : titre d'étape + total + action -->
    <div class="res-bar" id="res-bar">
      <div class="container res-bar-inner">
        <div class="res-bar-left">
          <button type="button" class="res-bar-back" id="res-back" aria-label="Étape précédente" hidden>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </button>
          <h1 class="res-bar-title" id="res-bar-title">{stepTitles[2]}</h1>
        </div>
        <div class="res-bar-right">
          <div class="res-bar-total">
            <span class="res-bar-total-line">Total : <strong id="res-bar-total">0€</strong></span>
            <button type="button" class="res-bar-details" id="res-price-details" aria-haspopup="true" aria-expanded="false">Détails du prix</button>
          </div>
          <button type="button" class="res-bar-next" id="res-next-top">Continuer</button>
        </div>
      </div>
      <!-- Popover détail du prix -->
      <div class="res-price-pop" id="res-price-pop" hidden>
        <div class="res-price-pop-card">
          <div class="res-price-pop-head">
            <strong>Détails du prix</strong>
            <button type="button" class="pk-close" id="res-price-pop-close" aria-label="Fermer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>
          <div class="res-price-pop-body" id="res-price-pop-body"></div>
        </div>
      </div>
    </div>

    <div class="container res-body">

      <!-- ÉTAPE 1 : Trajet -->
      <div class="res-step" data-step="1">
        <div class="res-panel">
          <div class="res-fields">
            <div class="res-field">
              <label>Retrait et retour</label>
              <button type="button" class="pk-trigger has-value res-loc" data-pk-open="loc" data-pk-input="res-pickup" aria-haspopup="dialog">
                <svg class="res-loc-icon" data-pk-icon width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
                <span data-pk-label>{agences[0].name}</span>
                <svg class="pk-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <input type="hidden" id="res-pickup" value={agences[0].id} />
            </div>

            <label class="res-check">
              <input type="checkbox" id="res-same-location" />
              <span class="res-check-box">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Je souhaite restituer la voiture à un autre endroit
            </label>

            <div class="res-field is-hidden" id="res-dropoff-field">
              <label>Lieu de retour</label>
              <button type="button" class="pk-trigger has-value res-loc" data-pk-open="loc" data-pk-input="res-dropoff" aria-haspopup="dialog">
                <svg class="res-loc-icon" data-pk-icon width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
                <span data-pk-label>{agences[0].name}</span>
                <svg class="pk-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <input type="hidden" id="res-dropoff" value={agences[0].id} />
            </div>

            <div class="res-dt-row">
              <div class="res-field">
                <label>Date de départ</label>
                <div class="res-dt">
                  <button type="button" class="pk-trigger res-dt-date" data-pk-open="range" data-pk-start="res-date-start" data-pk-end="res-date-end" aria-haspopup="dialog">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span data-pk-label>Choisir</span>
                  </button>
                  <div class="res-dt-time">
                    <select id="res-time-start" aria-label="Heure de départ">
                      {timeSlots.map((t) => <option value={t} selected={t === '10:00'}>{t}</option>)}
                    </select>
                  </div>
                </div>
              </div>
              <div class="res-field">
                <label>Date de retour</label>
                <div class="res-dt">
                  <button type="button" class="pk-trigger res-dt-date" data-pk-open="range" data-pk-role="end" data-pk-start="res-date-start" data-pk-end="res-date-end" aria-haspopup="dialog">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <span data-pk-label>Choisir</span>
                  </button>
                  <div class="res-dt-time">
                    <select id="res-time-end" aria-label="Heure de retour">
                      {timeSlots.map((t) => <option value={t} selected={t === '10:00'}>{t}</option>)}
                    </select>
                  </div>
                </div>
              </div>
            </div>

            <input type="hidden" id="res-date-start" value={today} />
            <input type="hidden" id="res-date-end" value="" />
          </div>

          <div class="res-step-actions">
            <button type="button" class="res-cta" id="res-go-2">Voir les véhicules</button>
          </div>
        </div>
      </div>

      <!-- ÉTAPE 2 : Véhicules (cartes sombres façon Sixt) -->
      <div class="res-step" data-step="2">
        <div class="res-toolbar">
          <div class="res-sort">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="16" y2="6"/><line x1="4" y1="12" x2="13" y2="12"/><line x1="4" y1="18" x2="10" y2="18"/><polyline points="17 9 20 12 17 15"/><line x1="20" y1="12" x2="14" y2="12"/></svg>
            <select id="res-sort" aria-label="Trier les véhicules">
              <option value="reco">Recommandé</option>
              <option value="price-asc">Prix croissant</option>
              <option value="price-desc">Prix décroissant</option>
            </select>
          </div>
          <div class="res-filters" id="res-veh-filters">
            <button type="button" class="res-filter is-active" data-filter="all" aria-pressed="true">Tous</button>
            <button type="button" class="res-filter" data-filter="citadine" aria-pressed="false">Citadines</button>
            <button type="button" class="res-filter" data-filter="suv" aria-pressed="false">SUV</button>
          </div>
        </div>

        <div class="res-veh-grid" id="res-veh-grid"></div>
      </div>

      <!-- ÉTAPE 3 : Protections -->
      <div class="res-step" data-step="3">
        <div class="res-info-banner">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/><line x1="12" y1="11" x2="12" y2="16" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12.01" y2="8" stroke="currentColor" stroke-width="2"/></svg>
          Les conducteurs doivent avoir leur permis de conduire depuis au moins 2 an(s) pour ce véhicule
        </div>

        <div class="res-protections">
          {protections.map((p) => (
            <div class={`res-protection ${p.id === 'essentielle' ? 'is-selected' : ''}`} data-protection={p.id} data-protection-price={p.price} role="button" tabindex="0">
              <div class="res-protection-top">
                <span class="res-protection-name">{p.name}</span>
                <span class="res-protection-radio" aria-hidden="true"></span>
              </div>
              <div class="res-protection-stars" aria-hidden="true">
                {Array.from({ length: 3 }).map((_, i) => (
                  <svg class={i < p.stars ? 'is-on' : ''} width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/></svg>
                ))}
                {p.remise && <em class="res-protection-remise">{p.remise}</em>}
              </div>
              <span class={`res-protection-franchise ${p.franchiseOk ? 'is-ok' : ''}`}>{p.franchise}</span>
              <ul class="res-protection-lines">
                {protectionRows.map((row, i) => (
                  <li class={p.covers[i] ? 'is-yes' : 'is-no'}>
                    <span class="res-protection-line-left">
                      {p.covers[i]
                        ? <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><polyline points="20 6 9 17 4 12"/></svg>
                        : <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>}
                      {row}
                    </span>
                    <svg class="res-protection-info" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="11" x2="12" y2="16"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                  </li>
                ))}
              </ul>
              <div class="res-protection-price">
                {p.price === 0
                  ? <strong>Inclus</strong>
                  : <>
                      <strong>{p.price}€ <small>/ jour</small></strong>
                      {p.strike && <s>{p.strike}€ / jour</s>}
                    </>}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- ÉTAPE 4 : Options -->
      <div class="res-step" data-step="4">
        <div class="res-info-banner">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/><line x1="12" y1="11" x2="12" y2="16" stroke="currentColor" stroke-width="2"/><line x1="12" y1="8" x2="12.01" y2="8" stroke="currentColor" stroke-width="2"/></svg>
          Les conducteurs doivent avoir leur permis de conduire depuis au moins 2 an(s) pour ce véhicule
        </div>

        <div class="res-options-layout">
          <div class="res-extras">
            {extras.map((e) => (
              <div class="res-extra" data-extra={e.id}>
                <span class="res-extra-icon" set:html={`<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">${extraIcons[e.icon]}</svg>`} />
                <div class="res-extra-body">
                  <span class="res-extra-label">{e.label}</span>
                  <span class="res-extra-price">{e.price.toFixed(2).replace('.', ',')} € <small>{e.perLabel}</small></span>
                  <button type="button" class="res-extra-details" data-extra-details={e.id}>Détails</button>
                  <span class="res-extra-desc" id={`extra-desc-${e.id}`} hidden>{e.desc}</span>
                </div>
                {e.stepper ? (
                  <div class="res-stepper-ctrl" data-stepper={e.id}>
                    <button type="button" class="res-stepper-btn" data-stepper-minus={e.id} aria-label="Retirer">−</button>
                    <span class="res-stepper-count" data-stepper-count={e.id}>0</span>
                    <button type="button" class="res-stepper-btn" data-stepper-plus={e.id} aria-label="Ajouter">+</button>
                  </div>
                ) : (
                  <button type="button" class="res-toggle" data-extra-toggle={e.id} role="switch" aria-checked="false" aria-label={e.label}>
                    <span class="res-toggle-knob"></span>
                  </button>
                )}
              </div>
            ))}
          </div>

          <aside class="res-apercu">
            <strong class="res-apercu-title">Aperçu de votre réservation :</strong>
            <ul class="res-apercu-list" id="res-apercu-list"></ul>
          </aside>
        </div>
      </div>

      <!-- ÉTAPE 5 : Revoir votre réservation -->
      <div class="res-step" data-step="5">
        <div class="res-review-layout">
          <div class="res-review-form">
            <h3 class="res-review-subtitle">Qui va conduire ?</h3>
            <div class="res-contact-fields">
              <div class="res-field res-field-full">
                <label for="res-email">Adresse e-mail</label>
                <input type="email" id="res-email" autocomplete="email" />
              </div>
              <div class="res-field">
                <label for="res-firstname">Prénom</label>
                <input type="text" id="res-firstname" autocomplete="given-name" />
              </div>
              <div class="res-field">
                <label for="res-name">Nom de famille</label>
                <input type="text" id="res-name" autocomplete="family-name" />
              </div>
              <div class="res-field res-field-country">
                <label for="res-country">Pays</label>
                <div class="res-country">
                  <select id="res-country" aria-label="Indicatif pays">
                    <option value="+33" selected>🇫🇷 +33</option>
                    <option value="+590">🇬🇵 +590</option>
                    <option value="+1">🇨🇦 +1</option>
                    <option value="+32">🇧🇪 +32</option>
                    <option value="+41">🇨🇭 +41</option>
                  </select>
                  <svg class="pk-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
              </div>
              <div class="res-field">
                <label for="res-phone">Numéro de téléphone</label>
                <input type="tel" id="res-phone" autocomplete="tel" />
              </div>
              <div class="res-field res-field-full">
                <label for="res-company">Entreprise <small>(optionnel)</small></label>
                <input type="text" id="res-company" autocomplete="organization" />
              </div>
            </div>

            <div class="res-whatsapp">
              <label class="res-radio">
                <input type="radio" name="whatsapp" value="oui" checked />
                <span class="res-radio-dot"></span>
                Oui, je souhaite recevoir des messages automatisés via WhatsApp concernant ma réservation.
              </label>
              <label class="res-radio">
                <input type="radio" name="whatsapp" value="non" />
                <span class="res-radio-dot"></span>
                Non, je ne souhaite pas recevoir de messages WhatsApp.
              </label>
            </div>

            <label class="res-terms">
              <input type="checkbox" id="res-terms-check" />
              <span class="res-check-box">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span>J'accepte les <a href="/conditions" target="_blank">conditions générales de location</a></span>
            </label>
          </div>

          <aside class="res-review-card" id="res-review-card"></aside>
        </div>
      </div>

      <!-- SUCCÈS -->
      <div class="res-success" id="res-success" hidden>
        <div class="res-success-check">
          <svg viewBox="0 0 52 52">
            <circle class="res-success-circle" cx="26" cy="26" r="24" fill="none"/>
            <path class="res-success-tick" fill="none" d="M14 27l7 7 17-17"/>
          </svg>
        </div>
        <h2 class="res-success-title">Réservation confirmée !</h2>
        <p class="res-success-text">Un email de confirmation a été envoyé avec votre numéro de dossier <strong id="res-ref"></strong>. Notre équipe vous contacte sous 24h.</p>
        <a href="/" class="btn btn-primary">Retour à l'accueil</a>
        <div class="res-confetti" aria-hidden="true"></div>
      </div>
    </div>

    <!-- Overlay + popups de sélection -->
    <div class="pk-overlay" data-pk-overlay hidden></div>

    <div class="pk-popup pk-popup-loc" data-pk-popup="loc" role="dialog" aria-label="Choisir une agence" hidden>
      <div class="pk-popup-head">
        <span>Choisir une agence</span>
        <button type="button" class="pk-close" data-pk-close aria-label="Fermer">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="pk-loc-split">
        <div class="pk-loc-list">
          <span class="pk-loc-list-title">Agences en Guadeloupe</span>
          {agences.map((a) => (
            <button type="button" class="pk-loc-item" data-loc-id={a.id} data-loc-name={a.name} data-loc-address={a.address} data-loc-hours={a.hours} data-loc-icon={a.id === 'aeroport-pole-caraibes' ? 'plane' : 'pin'}>
              <span class="pk-loc-icon">
                {a.id === 'aeroport-pole-caraibes'
                  ? <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
                  : <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>}
              </span>
              <span class="pk-loc-body">
                <span class="pk-loc-name">{a.name}</span>
                <span class="pk-loc-meta">{a.address}</span>
              </span>
              <span class="pk-loc-check">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
            </button>
          ))}
        </div>
        <div class="pk-loc-detail" data-pk-loc-detail></div>
      </div>
    </div>

    <div class="pk-popup pk-popup-range" data-pk-popup="range" role="dialog" aria-label="Choisir vos dates" hidden>
      <div class="pk-popup-head">
        <span>Sélectionnez vos dates</span>
        <button type="button" class="pk-close" data-pk-close aria-label="Fermer">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <div class="pk-range-wrap">
        <button type="button" class="pk-nav" data-pk-prev aria-label="Mois précédent">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="pk-months" data-pk-cal></div>
        <button type="button" class="pk-nav" data-pk-next aria-label="Mois suivant">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>

    <!-- Panneau détail véhicule (façon Sixt) -->
    <div class="veh-panel" id="veh-panel" hidden>
      <div class="veh-panel-card" role="dialog" aria-label="Détails du véhicule">
        <button type="button" class="veh-panel-close" id="veh-panel-close" aria-label="Fermer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <div class="veh-panel-media">
          <div class="veh-panel-name">
            <strong id="veh-panel-title"></strong>
            <span id="veh-panel-sub"></span>
          </div>
          <img id="veh-panel-img" src="" alt="" />
          <div class="veh-panel-media-foot">
            <span class="veh-panel-similar">Ou modèle similaire
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="11" x2="12" y2="16"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            </span>
            <ul class="veh-panel-specs" id="veh-panel-specs"></ul>
            <span class="veh-panel-age">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg>
              Âge minimum du conducteur : 21 ans
            </span>
          </div>
        </div>
        <div class="veh-panel-side">
          <div class="veh-panel-section">
            <h4 class="veh-panel-heading">Options de paiement</h4>
            <label class="veh-pay is-selected" data-pay="best">
              <input type="radio" name="pay-option" value="best" checked />
              <span class="veh-pay-radio"></span>
              <span class="veh-pay-body">
                <span class="veh-pay-name">Meilleur prix</span>
                <span class="veh-pay-desc">Payez maintenant, annulez et modifiez moyennant des frais</span>
              </span>
              <span class="veh-pay-price">Inclus</span>
            </label>
            <label class="veh-pay" data-pay="flex">
              <input type="radio" name="pay-option" value="flex" />
              <span class="veh-pay-radio"></span>
              <span class="veh-pay-body">
                <span class="veh-pay-name">Restez flexible <em class="veh-pay-pop">Populaire</em></span>
                <span class="veh-pay-desc">Payez à la prise en charge, annulez et modifiez gratuitement avant l'heure de prise en charge</span>
              </span>
              <span class="veh-pay-price">+ 4€ <small>/ jour</small></span>
            </label>
          </div>
          <div class="veh-panel-section">
            <h4 class="veh-panel-heading">Kilométrage</h4>
            <label class="veh-pay is-selected">
              <input type="radio" name="km-option" checked />
              <span class="veh-pay-radio"></span>
              <span class="veh-pay-body">
                <span class="veh-pay-name">Kilométrage illimité</span>
                <span class="veh-pay-desc">Tous les kilomètres sont inclus dans le prix</span>
              </span>
              <span class="veh-pay-price">Inclus</span>
            </label>
          </div>
          <div class="veh-panel-foot">
            <div class="veh-panel-price">
              <strong id="veh-panel-price"></strong>
              <button type="button" class="veh-panel-details" id="veh-panel-details">Détails du prix</button>
            </div>
            <button type="button" class="res-cta veh-panel-next" id="veh-panel-next">Suivant</button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script type="application/json" id="res-vehicles-data" set:html={vehiclesJson}></script>
<script type="application/json" id="res-extras-data" set:html={extrasJson}></script>
<script type="application/json" id="res-agences-data" set:html={agencesJson}></script>
<script type="application/json" id="res-protections-data" set:html={protectionsJson}></script>
<script type="application/json" id="res-badges-data" set:html={badgesJson}></script>
<script type="application/json" id="res-step-titles" set:html={stepTitlesJson}></script>

<style>
  /* ============ BARRE DE TUNNEL (style Sixt) ============ */
  .res-bar {
    position: sticky;
    top: 0;
    z-index: 200;
    background: #14171C;
    color: white;
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.25);
  }

  .res-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    min-height: 78px;
    padding-block: 10px;
  }

  .res-bar-left {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  .res-bar-back {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: white;
    cursor: pointer;
    flex-shrink: 0;
    transition: background var(--transition-fast);
  }

  .res-bar-back:hover {
    background: rgba(255, 255, 255, 0.12);
  }

  .res-bar-title {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2.2vw, 1.45rem);
    font-weight: 800;
    letter-spacing: 0.01em;
    color: white;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .res-bar-right {
    display: flex;
    align-items: center;
    gap: 22px;
    flex-shrink: 0;
  }

  .res-bar-total-line {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
    white-space: nowrap;
  }

  .res-bar-total-line strong {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: white;
    margin-left: 4px;
  }

  .res-bar-details {
    display: block;
    margin-top: 1px;
    background: none;
    border: none;
    padding: 0;
    font-size: 0.76rem;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    text-align: right;
    width: 100%;
  }

  .res-bar-details:hover {
    color: white;
  }

  .res-bar-next {
    background: var(--gradient-primary);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 15px 32px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.98rem;
    cursor: pointer;
    white-space: nowrap;
    box-shadow: 0 6px 18px rgba(227, 24, 55, 0.4);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .res-bar-next:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(227, 24, 55, 0.5);
  }

  /* Popover détail du prix */
  .res-price-pop {
    position: absolute;
    top: calc(100% + 6px);
    right: max(24px, calc((100vw - var(--max-width)) / 2 + 24px));
    z-index: 210;
  }

  .res-price-pop-card {
    width: min(360px, calc(100vw - 32px));
    background: white;
    color: var(--color-ink);
    border-radius: 14px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
    padding: 18px 20px;
    animation: pk-in 0.18s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .res-price-pop-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .res-price-pop-head strong {
    font-family: var(--font-display);
    font-size: 0.95rem;
  }

  .res-price-pop-head .pk-close {
    display: flex;
    width: 30px;
    height: 30px;
  }

  .res-price-pop-body :global(.res-pop-row) {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    padding: 4px 0;
  }

  .res-price-pop-body :global(.res-pop-row span:last-child) {
    font-weight: 600;
    color: var(--color-ink);
    white-space: nowrap;
  }

  .res-price-pop-body :global(.res-pop-row.is-discount span) {
    color: var(--color-turquoise);
  }

  .res-price-pop-body :global(.res-pop-total) {
    display: flex;
    justify-content: space-between;
    border-top: 1px solid var(--color-border);
    margin-top: 8px;
    padding-top: 10px;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--color-ink);
  }

  /* ============ CORPS DU TUNNEL ============ */
  .res {
    background: white;
    min-height: 70vh;
  }

  .res-body {
    padding-block: 34px 90px;
  }

  .res-step {
    display: none;
    animation: res-step-in 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .res-step.is-active {
    display: block;
  }

  @keyframes res-step-in {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .is-hidden {
    display: none !important;
  }

  /* ============ ÉTAPE 1 : trajet ============ */
  .res-panel {
    max-width: 720px;
    margin: 0 auto;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    padding: var(--spacing-xl);
  }

  .res-fields {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .res-field label {
    display: block;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 6px;
  }

  .res-field label small {
    font-weight: 500;
    color: var(--color-text-subtle);
  }

  .res-loc {
    width: 100%;
    background: white;
    border: 1.5px solid var(--color-border);
    border-radius: 10px;
    padding: 13px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.94rem;
    font-weight: 500;
    transition: border-color var(--transition-fast);
  }

  .res-loc:hover,
  .res-loc:focus-visible {
    border-color: var(--color-primary);
  }

  .res-loc-icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .res-loc [data-pk-label] {
    flex: 1;
    text-align: left;
  }

  .res-check {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    cursor: pointer;
  }

  .res-check input,
  .res-terms input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .res-check-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border: 1.5px solid var(--color-border-light);
    border-radius: 5px;
    color: transparent;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .res-check input:checked + .res-check-box,
  .res-terms input:checked + .res-check-box {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .res-dt-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .res-dt {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 8px;
  }

  .res-dt-date,
  .res-dt-time {
    display: flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1.5px solid var(--color-border);
    border-radius: 10px;
    padding: 13px 12px;
    font-size: 0.92rem;
    transition: border-color var(--transition-fast);
  }

  .res-dt-date {
    cursor: pointer;
  }

  .res-dt-date:hover {
    border-color: var(--color-primary);
  }

  .res-dt-date svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .res-dt-date [data-pk-label] {
    flex: 1;
    text-align: left;
  }

  .res-dt-date:not(.has-value) [data-pk-label] {
    color: var(--color-text-subtle);
  }

  .res-dt-time select {
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--color-ink);
    outline: none;
    cursor: pointer;
    width: 100%;
  }

  .res-step-actions {
    margin-top: 20px;
  }

  .res-cta {
    width: 100%;
    background: var(--gradient-primary);
    color: white;
    border: none;
    border-radius: 10px;
    padding: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    box-shadow: var(--shadow-primary);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .res-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(227, 24, 55, 0.4);
  }

  /* ============ ÉTAPE 2 : toolbar ============ */
  .res-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }

  .res-sort {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1.5px solid var(--color-border-light);
    border-radius: var(--radius-full);
    padding: 9px 16px;
    color: var(--color-ink);
  }

  .res-sort select {
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.86rem;
    color: var(--color-ink);
    outline: none;
    cursor: pointer;
  }

  .res-filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .res-filter {
    border: 1.5px solid var(--color-border-light);
    border-radius: var(--radius-full);
    background: white;
    padding: 9px 18px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.86rem;
    color: var(--color-ink);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .res-filter:hover:not(.is-active) {
    border-color: var(--color-ink);
  }

  .res-filter.is-active {
    background: #171B22;
    border-color: #171B22;
    color: white;
  }

  /* Grille véhicules : 3 colonnes façon Sixt */
  .res-veh-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  /* ============ ÉTAPE 3 : protections ============ */
  .res-info-banner {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 14px 18px;
    font-size: 0.88rem;
    color: var(--color-text-body);
    margin-bottom: 24px;
  }

  .res-info-banner svg {
    color: var(--color-ink);
    flex-shrink: 0;
  }

  .res-protections {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }

  .res-protection {
    display: flex;
    flex-direction: column;
    border: 1.5px solid var(--color-border);
    border-radius: 16px;
    padding: 20px;
    cursor: pointer;
    background: white;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .res-protection:hover {
    border-color: var(--color-border-light);
  }

  .res-protection.is-selected {
    border-color: #171B22;
    box-shadow: 0 0 0 1px #171B22;
  }

  .res-protection-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }

  .res-protection-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-ink);
    line-height: 1.25;
  }

  .res-protection-radio {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid #C9CDD4;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .res-protection.is-selected .res-protection-radio {
    border-color: #171B22;
    background: radial-gradient(circle at center, white 0 3px, #171B22 4px);
  }

  .res-protection-stars {
    display: flex;
    align-items: center;
    gap: 3px;
    color: #D5D9E0;
    margin-bottom: 10px;
    min-height: 22px;
  }

  .res-protection-stars .is-on {
    color: #171B22;
  }

  .res-protection-remise {
    font-style: normal;
    border: 1.5px solid var(--color-coral);
    color: var(--color-coral);
    font-size: 0.66rem;
    font-weight: 700;
    padding: 3px 9px;
    border-radius: var(--radius-full);
    margin-left: 8px;
    white-space: nowrap;
  }

  .res-protection-franchise {
    font-size: 0.84rem;
    font-weight: 700;
    color: #D92D20;
    margin-bottom: 14px;
  }

  .res-protection-franchise.is-ok {
    color: #079455;
  }

  .res-protection-lines {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 18px;
    flex: 1;
  }

  .res-protection-lines li {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
    font-size: 0.78rem;
    line-height: 1.35;
  }

  .res-protection-line-left {
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .res-protection-line-left svg {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .res-protection-lines .is-yes {
    color: var(--color-ink);
  }

  .res-protection-lines .is-yes .res-protection-line-left svg {
    color: #079455;
  }

  .res-protection-lines .is-no {
    color: #98A2B3;
  }

  .res-protection-info {
    color: #C9CDD4;
    flex-shrink: 0;
  }

  .res-protection-price strong {

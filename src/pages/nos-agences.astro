---
import BaseLayout from '../layouts/BaseLayout.astro';
import DestinationsGrid from '../components/DestinationsGrid.astro';
import CTASection from '../components/CTASection.astro';
---

<BaseLayout
  title="Nos Agences"
  description="Retrouvez les points de livraison Adventura en Guadeloupe : aéroport Guadeloupe Maryse Condé 24h/24 et Petit-Canal."
>
  <section class="page-hero">
    <div class="container">
      <span class="section-badge animate-on-scroll">Nos agences</span>
      <h1 class="page-hero-title animate-on-scroll" style="animation-delay:0.1s">
        Un point de retrait <span>proche de vous</span>
      </h1>
      <p class="page-hero-subtitle animate-on-scroll" style="animation-delay:0.2s">
        Livraison de votre véhicule à l'aéroport Guadeloupe Maryse Condé 24h/24 et à Petit-Canal, pour récupérer et restituer votre voiture sans détour.
      </p>
    </div>
  </section>

  <DestinationsGrid />
  <CTASection />
</BaseLayout>

<style>
  .page-hero {
    padding: calc(var(--nav-height) + var(--spacing-2xl)) 0 var(--spacing-xl);
    text-align: center;
    background: var(--gradient-glow);
  }

  .page-hero-title {
    margin: var(--spacing-sm) auto;
    max-width: 700px;
  }

  .page-hero-title span {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-hero-subtitle {
    max-width: 560px;
    margin: 0 auto;
  }
</style>

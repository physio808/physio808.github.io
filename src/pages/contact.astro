---
import BaseLayout from '../layouts/BaseLayout.astro';
import { agences } from '../data/data';
---

<BaseLayout
  title="Contact"
  description="Contactez l'équipe Adventura pour toute question sur votre location de voiture en Guadeloupe. Réponse sous 24h."
>
  <section class="page-hero">
    <div class="container">
      <span class="section-badge animate-on-scroll">Contact</span>
      <h1 class="page-hero-title animate-on-scroll" style="animation-delay:0.1s">
        Une question ? <span>Parlons-en</span>
      </h1>
      <p class="page-hero-subtitle animate-on-scroll" style="animation-delay:0.2s">
        Notre équipe locale répond sous 24h, 7j/7. Pour une urgence pendant votre location, contactez directement votre agence.
      </p>
    </div>
  </section>

  <section class="contact section">
    <div class="container contact-grid">
      <form class="contact-form animate-on-scroll">
        <div class="contact-form-row">
          <div class="res-field">
            <label for="c-name">Nom complet</label>
            <input type="text" id="c-name" placeholder="Jean Dupont" required />
          </div>
          <div class="res-field">
            <label for="c-email">Email</label>
            <input type="email" id="c-email" placeholder="jean.dupont@email.com" required />
          </div>
        </div>
        <div class="res-field">
          <label for="c-subject">Sujet</label>
          <select id="c-subject">
            <option>Question sur une réservation</option>
            <option>Demande de devis groupe</option>
            <option>Réclamation</option>
            <option>Partenariat</option>
            <option>Autre</option>
          </select>
        </div>
        <div class="res-field">
          <label for="c-message">Message</label>
          <textarea id="c-message" rows="5" placeholder="Comment pouvons-nous vous aider ?" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-lg contact-submit">
          Envoyer le message
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
        <p class="contact-confirm" id="contact-confirm" hidden>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Message envoyé, nous revenons vers vous sous 24h.
        </p>
      </form>

      <div class="contact-side animate-on-scroll" style="animation-delay:0.1s">
        <div class="contact-card">
          <h3>Coordonnées</h3>
          <div class="contact-card-row">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.4 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.54a16 16 0 0 0 6.29 6.29l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>06 90 48 47 76</span>
          </div>
          <div class="contact-card-row">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>Adventurarentals@gmail.com</span>
          </div>
          <div class="contact-card-row">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
            <span>Assistance téléphonique 7j/7, 7h-22h</span>
          </div>
        </div>

        <div class="contact-card">
          <h3>Nos agences</h3>
          <ul class="contact-agences">
            {agences.map((a) => (
              <li>
                <span class="contact-agence-name">{a.name}</span>
                <span class="contact-agence-hours">{a.hours}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: calc(var(--nav-height) + var(--spacing-2xl)) 0 var(--spacing-xl);
    text-align: center;
    background: var(--gradient-glow);
  }

  .page-hero-title {
    margin: var(--spacing-sm) auto;
    max-width: 700px;
  }

  .page-hero-title span {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-hero-subtitle {
    max-width: 560px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--spacing-2xl);
    align-items: start;
  }

  .contact-form {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .contact-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-md);
  }

  .res-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    transition: border-color var(--transition-fast), background var(--transition-fast);
  }

  .res-field:focus-within {
    border-color: var(--color-primary);
    background: rgba(227,24,55,0.06);
  }

  .res-field label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-subtle);
  }

  .res-field input,
  .res-field select,
  .res-field textarea {
    background: transparent;
    border: none;
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    width: 100%;
    resize: vertical;
    color-scheme: light;
  }

  .contact-submit {
    align-self: flex-start;
  }

  .contact-confirm {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-turquoise);
    font-size: 0.88rem;
  }

  .contact-side {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .contact-card {
    background: white;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
  }

  .contact-card h3 {
    font-size: 1rem;
    margin-bottom: var(--spacing-sm);
  }

  .contact-card-row {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 10px;
  }

  .contact-card-row svg {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contact-agences {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .contact-agences li {
    display: flex;
    justify-content: space-between;
    gap: var(--spacing-sm);
    font-size: 0.84rem;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--color-border);
  }

  .contact-agences li:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .contact-agence-name {
    color: var(--color-text);
    font-weight: 500;
  }

  .contact-agence-hours {
    color: var(--color-text-subtle);
  }

  @media (max-width: 1024px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .contact-form-row { grid-template-columns: 1fr; }
    .contact-form { padding: var(--spacing-lg); }
  }
</style>

<script>
  const form = document.querySelector('.contact-form');
  const confirmMsg = document.getElementById('contact-confirm');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (confirmMsg) {
      confirmMsg.hidden = false;
      confirmMsg.animate([{ opacity: 0, transform: 'translateY(6px)' }, { opacity: 1, transform: 'translateY(0)' }], { duration: 300 });
    }
    (form as HTMLFormElement).reset();
  });
</script>

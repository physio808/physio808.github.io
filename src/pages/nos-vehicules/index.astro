---
import BaseLayout from '../../layouts/BaseLayout.astro';
import VehicleCard from '../../components/VehicleCard.astro';
import { agences, categories, vehicles } from '../../data/data';

const agencesMapJson = JSON.stringify(
  Object.fromEntries(agences.map((a) => [a.id, a.name]))
);
---

<BaseLayout
  title="Nos Véhicules"
  description="Découvrez notre flotte complète : citadines, berlines, SUV & 4x4, cabriolets, électriques et familiaux. Kilométrage illimité, livraison aéroport gratuite."
>
  <section class="page-hero">
    <div class="container">
      <span class="section-badge animate-on-scroll">Notre flotte</span>
      <h1 class="page-hero-title animate-on-scroll" style="animation-delay:0.1s">
        <b id="fleet-title-count">{vehicles.length}</b> véhicules prêts <span>à prendre la route</span>
      </h1>
      <p class="page-hero-subtitle animate-on-scroll" style="animation-delay:0.2s" id="fleet-subtitle">
        Filtrez par catégorie pour trouver le véhicule adapté à votre séjour en Guadeloupe.
      </p>
      <div class="fleet-context" id="fleet-context" hidden>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span id="fleet-context-text"></span>
        <a href="/#booking-widget" class="fleet-context-edit">Modifier</a>
      </div>
    </div>
  </section>

  <section class="fleet-page section">
    <div class="container">
      <div class="fleet-toolbar animate-on-scroll">
        <div class="fleet-tabs" role="tablist">
          {categories.map((c) => (
            <button class="fleet-tab" data-cat={c.id} role="tab" aria-selected={c.id === 'all'}>
              <span>{c.icon}</span> {c.label}
            </button>
          ))}
        </div>
        <div class="fleet-sort">
          <label for="sort">Trier par</label>
          <select id="sort">
            <option value="default">Recommandés</option>
            <option value="price-asc">Prix croissant</option>
            <option value="price-desc">Prix décroissant</option>
            <option value="seats">Nombre de places</option>
          </select>
        </div>
      </div>

      <p class="fleet-count"><span id="fleet-count">{vehicles.length}</span> véhicules disponibles</p>

      <div class="fleet-grid" id="fleet-grid">
        {vehicles.map((v, i) => (
          <div class="fleet-grid-item" data-cat={v.categorySlug} data-veh-id={v.id} data-price={v.priceLow} data-price-high={v.priceHigh} data-seats={v.seats}>
            <VehicleCard vehicle={v} index={i} />
          </div>
        ))}
      </div>

      <p class="fleet-empty" id="fleet-empty" hidden>Aucun véhicule ne correspond à ce filtre pour le moment.</p>
    </div>
  </section>
</BaseLayout>

<script type="application/json" id="fleet-agences" set:html={agencesMapJson}></script>

<style>
  .page-hero {
    padding: calc(var(--nav-height) + var(--spacing-2xl)) 0 var(--spacing-xl);
    text-align: center;
    background: var(--gradient-glow);
  }

  .page-hero-title {
    margin: var(--spacing-sm) auto;
    max-width: 700px;
  }

  .page-hero-title span {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-hero-subtitle {
    max-width: 560px;
    margin: 0 auto;
  }

  .fleet-context {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: var(--spacing-md);
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 10px 18px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-ink);
    box-shadow: var(--shadow-card);
  }

  .fleet-context svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .fleet-context-edit {
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: underline;
  }

  .fleet-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-md);
  }

  .fleet-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .fleet-tab {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: var(--radius-full);
    background: white;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .fleet-tab:hover {
    border-color: var(--color-border-light);
    color: var(--color-text);
  }

  .fleet-tab[aria-selected="true"] {
    background: var(--gradient-primary);
    border-color: transparent;
    color: white;
    box-shadow: var(--shadow-primary);
  }

  .fleet-sort {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .fleet-sort label {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .fleet-sort select {
    background: white;
    border: 1px solid var(--color-border);
    color: var(--color-text);
    padding: 8px 14px;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.85rem;
    color-scheme: light;
  }

  .fleet-count {
    font-size: 0.85rem;
    color: var(--color-text-subtle);
    margin-bottom: var(--spacing-lg);
  }

  .fleet-count span {
    color: var(--color-primary);
    font-weight: 700;
  }

  .fleet-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    max-width: 1080px;
    margin-inline: auto;
  }

  .fleet-grid-item.is-hidden {
    display: none;
  }

  .fleet-empty {
    text-align: center;
    padding: var(--spacing-2xl) 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 1024px) {
    .fleet-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .fleet-grid { grid-template-columns: 1fr; }
    .fleet-toolbar { flex-direction: column; align-items: stretch; }
    .fleet-tabs { overflow-x: auto; flex-wrap: nowrap; padding-bottom: 8px; }
  }
</style>

<script>
  const tabs = document.querySelectorAll('.fleet-tab');
  const items = Array.from(document.querySelectorAll('.fleet-grid-item')) as HTMLElement[];
  const grid = document.getElementById('fleet-grid');
  const countEl = document.getElementById('fleet-count');
  const emptyEl = document.getElementById('fleet-empty');
  const sortEl = document.getElementById('sort') as HTMLSelectElement | null;
  let activeCat = 'all';

  function applyFilter() {
    let visibleCount = 0;
    items.forEach((item) => {
      const match = activeCat === 'all' || item.getAttribute('data-cat') === activeCat;
      item.classList.toggle('is-hidden', !match);
      if (match) visibleCount++;
    });
    if (countEl) countEl.textContent = String(visibleCount);
    const titleCount = document.getElementById('fleet-title-count');
    if (titleCount) titleCount.textContent = String(visibleCount);
    if (emptyEl) emptyEl.hidden = visibleCount !== 0;
  }

  function applySort() {
    if (!grid || !sortEl) return;
    const sorted = [...items].sort((a, b) => {
      const priceA = Number(a.getAttribute('data-price'));
      const priceB = Number(b.getAttribute('data-price'));
      const seatsA = Number(a.getAttribute('data-seats'));
      const seatsB = Number(b.getAttribute('data-seats'));
      switch (sortEl.value) {
        case 'price-asc': return priceA - priceB;
        case 'price-desc': return priceB - priceA;
        case 'seats': return seatsB - seatsA;
        default: return 0;
      }
    });
    sorted.forEach((item) => grid.appendChild(item));
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => t.setAttribute('aria-selected', 'false'));
      tab.setAttribute('aria-selected', 'true');
      activeCat = tab.getAttribute('data-cat') || 'all';
      applyFilter();
    });
  });

  sortEl?.addEventListener('change', applySort);

  const params = new URLSearchParams(window.location.search);
  const catParam = params.get('categorie');
  if (catParam) {
    const target = Array.from(tabs).find((t) => t.getAttribute('data-cat') === catParam);
    if (target) (target as HTMLElement).click();
  }

  /* ── Contexte de recherche (dates choisies sur l'accueil) ── */

  function isHighSeason(d: Date): boolean {
    const month = d.getMonth() + 1;
    const day = d.getDate();
    if (month === 12) return day >= 20;
    if (month < 4) return true;
    if (month === 4) return day <= 20;
    return false;
  }

  function seasonBreakdown(startISO: string, days: number): { high: number; low: number } {
    let high = 0;
    let low = 0;
    const start = new Date(startISO + 'T12:00:00');
    for (let i = 0; i < days; i++) {
      const d = new Date(start);
      d.setDate(start.getDate() + i);
      if (isHighSeason(d)) high++;
      else low++;
    }
    return { high, low };
  }

  const fmtDay = (dstr: string) =>
    new Date(dstr + 'T00:00:00').toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'short' });

  const dateStart = params.get('date-start');
  const dateEnd = params.get('date-end');

  const fmtEUR = (n: number) =>
    (Number.isInteger(n) ? String(n) : n.toFixed(2).replace('.', ',')) + '€';

  if (dateStart && dateEnd) {
    const days = Math.max(1, Math.round((new Date(dateEnd).getTime() - new Date(dateStart).getTime()) / 86400000));
    const bd = seasonBreakdown(dateStart, days);
    const discountApplies = days >= 7;

    items.forEach((item) => {
      const low = Number(item.getAttribute('data-price'));
      const high = Number(item.getAttribute('data-price-high'));
      const gross = bd.low * low + bd.high * high;
      const total = discountApplies ? Math.round(gross * 0.8 * 100) / 100 : gross;
      const perDay = Math.round((total / days) * 100) / 100;

      const fromEl = item.querySelector('.v-card-price-from');
      const amountEl = item.querySelector('.v-card-price-amount');
      const unitEl = item.querySelector('.v-card-price-unit');
      if (fromEl) fromEl.textContent = 'total';
      if (amountEl) amountEl.textContent = fmtEUR(total);
      if (unitEl) unitEl.textContent = `/${days} j`;

      // Ligne de détail transparente sous le titre
      const head = item.querySelector('.v-card-head');
      if (head && !item.querySelector('.v-card-deal')) {
        const deal = document.createElement('p');
        deal.className = 'v-card-deal';
        deal.innerHTML = discountApplies
          ? `soit ${fmtEUR(perDay)}/jour · <strong>−20% appliqué</strong> · <s>${fmtEUR(gross)}</s>`
          : `soit ${fmtEUR(perDay)}/jour pour vos dates`;
        head.insertAdjacentElement('afterend', deal);
      }

      // Boutons : réservation directe + fiche avec contexte conservé
      const vehId = item.getAttribute('data-veh-id');
      const qs = params.toString();
      const reserveBtn = item.querySelector('[data-v-reserve]');
      if (reserveBtn && vehId) {
        reserveBtn.setAttribute('href', `/reservation?vehicule=${vehId}&${qs}`);
      }
      item.querySelectorAll('[data-v-detail]').forEach((a) => {
        const base = a.getAttribute('href')?.split('?')[0];
        if (base) a.setAttribute('href', `${base}?${qs}`);
      });
    });

    const agMap = JSON.parse(document.getElementById('fleet-agences')?.textContent || '{}');
    const pickupId = params.get('pickup') || '';
    const dropId = params.get('dropoff') || pickupId;
    const timeStart = params.get('time-start') || '09:00';
    const timeEnd = params.get('time-end') || '17:00';

    const ctx = document.getElementById('fleet-context');
    const txt = document.getElementById('fleet-context-text');
    if (ctx && txt) {
      const agTxt = agMap[pickupId]
        ? ` · ${agMap[pickupId]}${dropId !== pickupId && agMap[dropId] ? ' → ' + agMap[dropId] : ''}`
        : '';
      txt.textContent = `Du ${fmtDay(dateStart)} ${timeStart} au ${fmtDay(dateEnd)} ${timeEnd}${agTxt} · ${days} jour${days > 1 ? 's' : ''}`;
      ctx.hidden = false;
    }

    const subtitle = document.getElementById('fleet-subtitle');
    if (subtitle) {
      subtitle.textContent = 'Prix total affiché pour vos dates, kilométrage illimité et assurance inclus. Cliquez sur un véhicule pour finaliser en 1 minute.';
    }
  }
</script>

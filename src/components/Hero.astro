---
import { agences } from '../data/data';

const timeSlots: string[] = [];
for (let h = 7; h <= 19; h++) {
  timeSlots.push(`${String(h).padStart(2, '0')}:00`);
  if (h < 19) timeSlots.push(`${String(h).padStart(2, '0')}:30`);
}

const ages = ['21 - 25 ans', '26 ans et plus'];

const args = [
  {
    icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
    title: 'Loueur 100% local',
    text: 'Une équipe basée en Guadeloupe et 6 points de retrait sur l\'île, de l\'aéroport à Deshaies.',
  },
  {
    icon: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><path d="M9 14l2 2 4-4"/>',
    title: 'Annulation gratuite',
    text: 'Annulez ou modifiez sans frais jusqu\'à 48h avant le début de votre location.',
  },
  {
    icon: '<path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/>',
    title: 'Prix transparents',
    text: 'Kilométrage illimité et assurance inclus. Le prix affiché est le prix payé, sans surprise.',
  },
  {
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>',
    title: 'Disponibles 7j/7',
    text: 'Téléphone et WhatsApp tous les jours, livraison à l\'aéroport 24h/24 même en vol de nuit.',
  },
];
---

<section class="hero" id="hero-booking">
  <div class="hero-bg" aria-hidden="true">
    <img src="/images/hero-plage.webp" alt="" fetchpriority="high" width="1920" height="1276" />
    <div class="hero-bg-overlay"></div>
  </div>

  <div class="container hero-inner">
    <!-- Carte de réservation (gauche) -->
    <form class="hero-card hb-form" action="/reservation" method="get">
      <div class="hb-tabs" role="tablist" aria-label="Type de véhicule">
        <button type="button" class="hb-tab is-active" role="tab" aria-selected="true" data-hb-tab="voitures">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 3H5L3 10v9h2v2h2v-2h10v2h2v-2h2v-9z"/><circle cx="7" cy="15" r="1.5"/><circle cx="17" cy="15" r="1.5"/></svg>
          Voitures
        </button>
        <button type="button" class="hb-tab" role="tab" aria-selected="false" data-hb-tab="utilitaires">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 8h13v9H1z"/><path d="M14 11h4l3 3v3h-7z"/><circle cx="5.5" cy="17.5" r="1.5"/><circle cx="17.5" cy="17.5" r="1.5"/></svg>
          Utilitaires
        </button>
      </div>

      <div class="hb-utilitaires" id="hb-utilitaires-note" hidden>
        <strong>Utilitaires sur demande</strong>
        <p>Nous proposons des utilitaires à la location sur devis. Appelez-nous ou écrivez-nous, réponse dans l'heure aux horaires d'ouverture.</p>
        <a href="tel:+590690484776" class="hb-utilitaires-cta">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.4 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.54a16 16 0 0 0 6.29 6.29l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          06 90 48 47 76
        </a>
      </div>

      <div class="hb-fields" id="hb-fields">
      <h1 class="hero-card-title">Location de voiture en Guadeloupe</h1>

      <div class="hb-field">
        <label>Retrait et retour</label>
        <button type="button" class="pk-trigger has-value hb-loc" data-pk-open="loc" data-pk-input="pickup" aria-haspopup="dialog">
          <svg class="hb-loc-pin" data-pk-icon width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
          <span data-pk-label>{agences[0].name}</span>
          <svg class="pk-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <input type="hidden" id="pickup" name="pickup" value={agences[0].id} />
      </div>

      <label class="hb-check">
        <input type="checkbox" id="hb-toggle-dropoff" />
        <span class="hb-check-box">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        Je souhaite restituer la voiture à un autre endroit
      </label>

      <div class="hb-field hb-field-dropoff is-hidden" id="hb-dropoff-field">
        <label>Lieu de retour</label>
        <button type="button" class="pk-trigger has-value hb-loc" data-pk-open="loc" data-pk-input="dropoff" aria-haspopup="dialog">
          <svg class="hb-loc-pin" data-pk-icon width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
          <span data-pk-label>{agences[0].name}</span>
          <svg class="pk-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <input type="hidden" id="dropoff" name="dropoff" value={agences[0].id} />
      </div>

      <div class="hb-field">
        <label>Date de départ</label>
        <div class="hb-dt">
          <button type="button" class="pk-trigger hb-dt-date" data-pk-open="range" data-pk-start="date-start" data-pk-end="date-end" aria-haspopup="dialog">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span data-pk-label>Choisir</span>
          </button>
          <div class="hb-dt-time">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
            <select id="time-start" name="time-start" aria-label="Heure de départ">
              {timeSlots.map((t) => <option value={t} selected={t === '09:00'}>{t}</option>)}
            </select>
          </div>
        </div>
      </div>

      <div class="hb-field">
        <label>Date de retour</label>
        <div class="hb-dt">
          <button type="button" class="pk-trigger hb-dt-date" data-pk-open="range" data-pk-role="end" data-pk-start="date-start" data-pk-end="date-end" aria-haspopup="dialog">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span data-pk-label>Choisir</span>
          </button>
          <div class="hb-dt-time">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
            <select id="time-end" name="time-end" aria-label="Heure de retour">
              {timeSlots.map((t) => <option value={t} selected={t === '17:00'}>{t}</option>)}
            </select>
          </div>
        </div>
      </div>

      <div class="hb-row-2">
        <div class="hb-field">
          <label>Âge du conducteur</label>
          <div class="hb-select">
            <select id="age" name="age" aria-label="Âge du conducteur">
              {ages.map((a, i) => <option value={a} selected={i === 1}>{a}</option>)}
            </select>
            <svg class="pk-chevron" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </div>
        <div class="hb-field">
          <label>Code promo</label>
          <input type="text" id="promo" name="promo" class="hb-input" placeholder="Optionnel" />
        </div>
      </div>

      <input type="hidden" id="date-start" name="date-start" value="" />
      <input type="hidden" id="date-end" name="date-end" value="" />

      <button type="submit" class="hb-submit">Voir les véhicules</button>
      </div>
    </form>

    <!-- Arguments (droite) -->
    <div class="hero-side">
      <ul class="hero-side-list">
        {args.map((r) => (
          <li>
            <span class="hero-side-icon" set:html={`<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">${r.icon}</svg>`} />
            <span>
              <strong>{r.title}</strong>
              <small>{r.text}</small>
            </span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Overlay + popups -->
  <div class="pk-overlay" data-pk-overlay hidden></div>

  <div class="pk-popup pk-popup-loc" data-pk-popup="loc" role="dialog" aria-label="Choisir une agence" hidden>
    <div class="pk-popup-head">
      <span>Choisir une agence</span>
      <button type="button" class="pk-close" data-pk-close aria-label="Fermer">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="pk-loc-split">
      <div class="pk-loc-list">
        <span class="pk-loc-list-title">Agences en Guadeloupe</span>
        {agences.map((a) => (
          <button type="button" class="pk-loc-item" data-loc-id={a.id} data-loc-name={a.name} data-loc-address={a.address} data-loc-hours={a.hours} data-loc-icon={a.id === 'aeroport-pole-caraibes' ? 'plane' : 'pin'}>
            <span class="pk-loc-icon">
              {a.id === 'aeroport-pole-caraibes'
                ? <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>
                : <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>}
            </span>
            <span class="pk-loc-body">
              <span class="pk-loc-name">{a.name}</span>
              <span class="pk-loc-meta">{a.address}</span>
            </span>
            <span class="pk-loc-check">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
          </button>
        ))}
      </div>
      <div class="pk-loc-detail" data-pk-loc-detail></div>
    </div>
  </div>

  <div class="pk-popup pk-popup-range" data-pk-popup="range" role="dialog" aria-label="Choisir vos dates" hidden>
    <div class="pk-popup-head">
      <span>Sélectionnez vos dates</span>
      <button type="button" class="pk-close" data-pk-close aria-label="Fermer">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="pk-range-wrap">
      <button type="button" class="pk-nav" data-pk-prev aria-label="Mois précédent">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="pk-months" data-pk-cal></div>
      <button type="button" class="pk-nav" data-pk-next aria-label="Mois suivant">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
    <p class="pk-range-hint">Choisissez d'abord la date de départ, puis la date de retour.</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 55%;
    /* léger blur artistique */
    filter: blur(3px) brightness(0.98);
    transform: scale(1.06);
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(8, 22, 38, 0.32) 0%, rgba(8, 22, 38, 0.12) 45%, rgba(8, 22, 38, 0.28) 100%);
  }

  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 440px 1fr;
    gap: var(--spacing-2xl);
    align-items: center;
    padding-block: var(--spacing-xl);
    min-height: 620px;
  }

  /* ===== Carte de réservation ===== */
  .hero-card {
    background: white;
    border-radius: var(--radius-lg);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.3);
    padding: var(--spacing-lg);
    animation: fadeInUp 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hb-fields {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* Onglets type de véhicule (style Sixt) */
  .hb-tabs {
    display: flex;
    gap: 6px;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 5px;
    margin-bottom: 14px;
  }

  .hb-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 12px;
    border: none;
    border-radius: var(--radius-full);
    background: transparent;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.86rem;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .hb-tab:hover:not(.is-active) {
    color: var(--color-ink);
  }

  .hb-tab.is-active {
    background: var(--color-ink);
    color: white;
    box-shadow: 0 4px 12px rgba(22, 32, 46, 0.25);
  }

  /* Panneau utilitaires */
  .hb-utilitaires {
    background: var(--color-bg-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    text-align: center;
    animation: fadeIn 0.3s ease;
  }

  .hb-utilitaires strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.02rem;
    color: var(--color-ink);
    margin-bottom: 6px;
  }

  .hb-utilitaires p {
    font-size: 0.86rem;
    margin-bottom: 14px;
  }

  .hb-utilitaires-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--gradient-primary);
    color: white;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 12px 26px;
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-primary);
    transition: transform var(--transition-fast);
  }

  .hb-utilitaires-cta:hover {
    transform: translateY(-2px);
  }

  .hero-card-title {
    font-size: 1.3rem;
    line-height: 1.3;
    margin-bottom: 4px;
  }

  .hb-field label {
    display: block;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-ink);
    margin-bottom: 6px;
  }

  /* Déclencheur lieu (avec pin) */
  .hb-loc {
    width: 100%;
    background: white;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.94rem;
    font-weight: 500;
    color: var(--color-ink);
    cursor: pointer;
    transition: border-color var(--transition-fast);
  }

  .hb-loc:hover,
  .hb-loc:focus-visible {
    border-color: var(--color-primary);
  }

  .hb-loc-pin {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .hb-loc [data-pk-label] {
    flex: 1;
    text-align: left;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .hb-loc .pk-chevron {
    color: var(--color-text-subtle);
    flex-shrink: 0;
  }

  /* Checkbox retour */
  .hb-check {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    cursor: pointer;
    margin: -2px 0 2px;
  }

  .hb-check input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .hb-check-box {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border: 1.5px solid var(--color-border-light);
    border-radius: 5px;
    color: transparent;
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .hb-check input:checked + .hb-check-box {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  /* Date + heure */
  .hb-dt {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 10px;
  }

  .hb-dt-date,
  .hb-dt-time {
    display: flex;
    align-items: center;
    gap: 8px;
    background: white;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    transition: border-color var(--transition-fast);
  }

  .hb-dt-date {
    cursor: pointer;
    font-size: 0.94rem;
    color: var(--color-ink);
  }

  .hb-dt-date:hover {
    border-color: var(--color-primary);
  }

  .hb-dt-date svg,
  .hb-dt-time svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .hb-dt-date [data-pk-label] {
    flex: 1;
    text-align: left;
  }

  .hb-dt-date:not(.has-value) [data-pk-label] {
    color: var(--color-text-subtle);
  }

  .hb-dt-time select {
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.94rem;
    font-weight: 500;
    color: var(--color-ink);
    outline: none;
    cursor: pointer;
    width: 100%;
  }

  /* Âge + code promo */
  .hb-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .hb-select {
    position: relative;
  }

  .hb-select select {
    width: 100%;
    appearance: none;
    background: white;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 12px 34px 12px 14px;
    font-family: var(--font-body);
    font-size: 0.94rem;
    font-weight: 500;
    color: var(--color-ink);
    outline: none;
    cursor: pointer;
  }

  .hb-select select:hover {
    border-color: var(--color-primary);
  }

  .hb-select .pk-chevron {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-subtle);
    pointer-events: none;
  }

  .hb-input {
    width: 100%;
    background: white;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 12px 14px;
    font-family: var(--font-body);
    font-size: 0.94rem;
    color: var(--color-ink);
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .hb-input:focus {
    border-color: var(--color-primary);
  }

  .hb-field-dropoff.is-hidden {
    display: none;
  }

  .hb-submit {
    background: var(--gradient-primary);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    padding: 16px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: var(--shadow-primary);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    margin-top: 4px;
  }

  .hb-submit:hover {
    transform: translateY(-2px);

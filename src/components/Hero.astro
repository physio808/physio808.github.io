---
import { agences } from '../data/data';

const today = new Date().toISOString().split('T')[0];

const timeSlots: string[] = [];
for (let h = 7; h <= 19; h++) {
  timeSlots.push(`${String(h).padStart(2, '0')}:00`);
  if (h < 19) timeSlots.push(`${String(h).padStart(2, '0')}:30`);
}

const reassurance = [
  {
    icon: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
    title: 'Loueur 100% local',
    text: 'Une équipe basée en Guadeloupe, 6 points de retrait sur l\'île',
  },
  {
    icon: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><path d="M9 14l2 2 4-4"/>',
    title: 'Annulation gratuite',
    text: 'Jusqu\'à 48h avant le départ, sans justification',
  },
  {
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>',
    title: 'Aéroport 24h/24',
    text: 'Livraison gratuite à Pôle Caraïbes, même pour les vols de nuit',
  },
  {
    icon: '<path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6z"/><path d="M9 12l2 2 4-4"/>',
    title: 'Kilométrage illimité',
    text: 'Assurance incluse, zéro frais caché',
  },
];
---

<section class="hero" id="hero-booking">
  <div class="hero-bg" aria-hidden="true">
    <img src="/images/hero-beach.jpg" alt="" fetchpriority="high" />
    <div class="hero-bg-overlay"></div>
  </div>

  <div class="container hero-inner">
    <!-- Carte de réservation -->
    <div class="hero-card">
      <h1 class="hero-card-title">Location de voiture en Guadeloupe</h1>

      <form class="hb-form" action="/nos-vehicules" method="get">
        <div class="hb-field">
          <label>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Lieu de départ
          </label>
          <button type="button" class="pk-trigger has-value" data-pk-open="loc" data-pk-input="pickup" aria-haspopup="dialog">
            <span data-pk-label>{agences[0].name}</span>
            <svg class="pk-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <input type="hidden" id="pickup" name="pickup" value={agences[0].id} />
        </div>

        <button type="button" class="hb-toggle-dropoff" id="hb-toggle-dropoff">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Lieu de retour différent
        </button>

        <div class="hb-field hb-field-dropoff is-hidden" id="hb-dropoff-field">
          <label>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Lieu de retour
          </label>
          <button type="button" class="pk-trigger has-value" data-pk-open="loc" data-pk-input="dropoff" aria-haspopup="dialog">
            <span data-pk-label>{agences[0].name}</span>
            <svg class="pk-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <input type="hidden" id="dropoff" name="dropoff" value={agences[0].id} />
        </div>

        <div class="hb-row">
          <div class="hb-field hb-field-date">
            <label>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Date de départ
            </label>
            <button type="button" class="pk-trigger" data-pk-open="dt" data-pk-date="date-start" data-pk-time="time-start-mirror" data-pk-default-time="09:00" data-pk-chain="date-end" aria-haspopup="dialog">
              <span data-pk-label>Choisir une date</span>
              <svg class="pk-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <input type="hidden" id="date-start" name="date-start" value={today} />
            <input type="hidden" id="time-start-mirror" value="" />
          </div>
          <div class="hb-field hb-field-time">
            <label>Heure</label>
            <select id="time-start" name="time-start" aria-label="Heure de départ">
              {timeSlots.map((t) => <option value={t} selected={t === '09:00'}>{t}</option>)}
            </select>
          </div>
        </div>

        <div class="hb-row">
          <div class="hb-field hb-field-date">
            <label>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Date de retour
            </label>
            <button type="button" class="pk-trigger" data-pk-open="dt" data-pk-date="date-end" data-pk-time="time-end-mirror" data-pk-default-time="17:00" data-pk-min-from="date-start" aria-haspopup="dialog">
              <span data-pk-label>Choisir une date</span>
              <svg class="pk-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <input type="hidden" id="date-end" name="date-end" value="" />
            <input type="hidden" id="time-end-mirror" value="" />
          </div>
          <div class="hb-field hb-field-time">
            <label>Heure</label>
            <select id="time-end" name="time-end" aria-label="Heure de retour">
              {timeSlots.map((t) => <option value={t} selected={t === '17:00'}>{t}</option>)}
            </select>
          </div>
        </div>

        <button type="submit" class="hb-submit">
          Voir les véhicules
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>
    </div>

    <!-- Réassurance -->
    <div class="hero-side">
      <p class="hero-side-heading">Explorez l'archipel<br />à votre rythme.</p>
      <ul class="hero-side-list">
        {reassurance.map((r) => (
          <li>
            <span class="hero-side-icon" set:html={`<svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">${r.icon}</svg>`} />
            <span>
              <strong>{r.title}</strong>
              <small>{r.text}</small>
            </span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Overlay + popups -->
  <div class="pk-overlay" data-pk-overlay hidden></div>

  <div class="pk-popup" data-pk-popup="loc" role="dialog" aria-label="Choisir une agence" hidden>
    <div class="pk-popup-head">
      <span>Choisir une agence</span>
      <button type="button" class="pk-close" data-pk-close aria-label="Fermer">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="pk-loc-list">
      {agences.map((a) => (
        <button type="button" class="pk-loc-item" data-loc-id={a.id} data-loc-name={a.name}>
          <span class="pk-loc-icon">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <span class="pk-loc-body">
            <span class="pk-loc-name">{a.name}</span>
            <span class="pk-loc-meta">{a.address}</span>
            <span class="pk-loc-hours">{a.hours}</span>
          </span>
          <span class="pk-loc-check">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
        </button>
      ))}
    </div>
  </div>

  <div class="pk-popup" data-pk-popup="dt" role="dialog" aria-label="Choisir une date" hidden>
    <div class="pk-popup-head">
      <div class="pk-cal-nav">
        <button type="button" class="pk-nav" data-pk-prev aria-label="Mois précédent">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <span class="pk-cal-title" data-pk-cal-title></span>
        <button type="button" class="pk-nav" data-pk-next aria-label="Mois suivant">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
      <button type="button" class="pk-close" data-pk-close aria-label="Fermer">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="pk-cal-grid" data-pk-cal></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(10, 18, 30, 0.55) 0%, rgba(10, 18, 30, 0.25) 45%, rgba(10, 18, 30, 0.45) 100%),
      linear-gradient(180deg, rgba(10, 18, 30, 0.35) 0%, transparent 30%);
  }

  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: var(--spacing-2xl);
    align-items: center;
    padding-block: var(--spacing-xl);
    min-height: 620px;
  }

  /* ===== Carte de réservation ===== */
  .hero-card {
    background: white;
    border-radius: var(--radius-lg);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
    padding: var(--spacing-lg);
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-card-title {
    font-size: 1.25rem;
    line-height: 1.3;
    margin-bottom: var(--spacing-md);
  }

  .hb-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .hb-field {
    background: var(--color-bg-soft);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 9px 14px;
    transition: border-color var(--transition-fast);
  }

  .hb-field:focus-within,
  .hb-field:hover {
    border-color: var(--color-primary);
  }

  .hb-field label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: 2px;
  }

  .hb-field label svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .hb-field select {
    width: 100%;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-ink);
    outline: none;
    cursor: pointer;
    padding: 2px 0;
  }

  .hb-row {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 10px;
  }

  .hb-toggle-dropoff {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color var(--transition-fast);
  }

  .hb-toggle-dropoff:hover {
    color: var(--color-primary);
  }

  .hb-toggle-dropoff.is-active {
    color: var(--color-primary);
  }

  .hb-field-dropoff {
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.25s ease, padding 0.35s ease, border-width 0.35s ease, margin 0.35s ease;
    max-height: 80px;
  }

  .hb-field-dropoff.is-hidden {
    max-height: 0;
    opacity: 0;
    padding-top: 0;
    padding-bottom: 0;
    border-width: 0;
    margin: -10px 0 0;
  }

  .hb-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: var(--gradient-primary);
    color: white;
    border: none;
    border-radius: var(--radius-md);
    padding: 15px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    box-shadow: var(--shadow-primary);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    margin-top: 4px;
  }

  .hb-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(227, 24, 55, 0.4);
  }

  .hb-submit:active {
    transform: translateY(0) scale(0.99);
  }

  /* ===== Réassurance ===== */
  .hero-side {
    color: white;
    animation: fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
    justify-self: end;
    max-width: 460px;
  }

  .hero-side-heading {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    font-weight: 800;
    line-height: 1.2;
    color: white;
    margin-bottom: var(--spacing-lg);
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
  }

  .hero-side-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .hero-side-list li {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .hero-side-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: white;
    flex-shrink: 0;
  }

  .hero-side-list strong {
    display: block;
    font-family: var(--font-display);
    font-size: 0.98rem;
    font-weight: 700;
    color: white;
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.35);
  }

  .hero-side-list small {
    display: block;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.88);
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
      min-height: 0;
      padding-block: var(--spacing-lg) var(--spacing-xl);
    }

    .hero-card {
      order: 1;
      max-width: 480px;
      width: 100%;
      margin: 0 auto;
    }

    .hero-side {
      order: 2;
      justify-self: center;
      max-width: 480px;
      width: 100%;
    }

    .hero-side-heading {
      text-align: center;
      margin-bottom: var(--spacing-md);
    }

    .hero-side-list {
      gap: 12px;
    }
  }

  @media (max-width: 640px) {
    .hero-card {
      padding: var(--spacing-md);
    }

    .hb-row {
      grid-template-columns: 1.4fr 1fr;
    }

    .hero-side-list li small {
      font-size: 0.78rem;
    }
  }
</style>

<script>
  import { setupPickers } from '../scripts/pickers';

  setupPickers('hero-booking');

  // Lieu de retour différent
  const toggleBtn = document.getElementById('hb-toggle-dropoff');
  const dropField = document.getElementById('hb-dropoff-field');
  toggleBtn?.addEventListener('click', () => {
    const hidden = dropField?.classList.toggle('is-hidden');
    toggleBtn.classList.toggle('is-active', !hidden);
  });

  // Si le retour est masqué, il suit le lieu de départ
  const heroForm = document.querySelector('#hero-booking .hb-form') as HTMLFormElement | null;
  heroForm?.addEventListener('submit', (e) => {
    const pickup = document.getElementById('pickup') as HTMLInputElement | null;
    const dropoff = document.getElementById('dropoff') as HTMLInputElement | null;
    if (dropField?.classList.contains('is-hidden') && pickup && dropoff) {
      dropoff.value = pickup.value;
    }
    const dateEnd = document.getElementById('date-end') as HTMLInputElement | null;
    if (dateEnd && !dateEnd.value) {
      e.preventDefault();
      document.querySelector<HTMLElement>('#hero-booking [data-pk-date="date-end"]')?.click();
    }
  });
</script>

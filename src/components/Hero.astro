<script>
  import { setupPickers } from '../scripts/pickers';

  setupPickers('hero-booking');

  // Onglets Voitures / Utilitaires
  const hbTabs = document.querySelectorAll('#hero-booking .hb-tab');
  const hbFields = document.getElementById('hb-fields');
  const hbNote = document.getElementById('hb-utilitaires-note');
  hbTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      hbTabs.forEach((t) => {
        t.classList.toggle('is-active', t === tab);
        t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
      });
      const isUtil = tab.getAttribute('data-hb-tab') === 'utilitaires';
      if (hbFields) hbFields.hidden = isUtil;
      if (hbNote) hbNote.hidden = !isUtil;
    });
  });

  // Lieu de retour différent
  const toggleBox = document.getElementById('hb-toggle-dropoff') as HTMLInputElement | null;
  const dropField = document.getElementById('hb-dropoff-field');
  toggleBox?.addEventListener('change', () => {
    dropField?.classList.toggle('is-hidden', !toggleBox.checked);
  });

  // Si le retour est masqué, il suit le lieu de départ
  const heroForm = document.querySelector('#hero-booking .hb-form') as HTMLFormElement | null;
  heroForm?.addEventListener('submit', (e) => {
    const pickup = document.getElementById('pickup') as HTMLInputElement | null;
    const dropoff = document.getElementById('dropoff') as HTMLInputElement | null;
    if (!toggleBox?.checked && pickup && dropoff) {
      dropoff.value = pickup.value;
    }
    const dateEnd = document.getElementById('date-end') as HTMLInputElement | null;
    if (dateEnd && !dateEnd.value) {
      e.preventDefault();
      document.querySelector<HTMLElement>('#hero-booking [data-pk-open="range"]')?.click();
    }
  });
</script>

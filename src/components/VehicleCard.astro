---
import type { Vehicle } from '../data/data';

export interface Props {
  vehicle: Vehicle;
  index?: number;
}

const { vehicle, index = 0 } = Astro.props;
---

<article class="v-card animate-on-scroll" style={`--i:${index % 4}`}>
  <div class="v-card-box">
    <a href={`/nos-vehicules/${vehicle.id}`} class="v-card-visual" data-v-detail aria-label={`Voir la fiche ${vehicle.name}`}>
      <div class="v-card-visual-head">
        <span class="v-card-title">{vehicle.name}</span>
        <span class="v-card-subtitle">{vehicle.category} · {vehicle.transmission}</span>
        <span class="v-card-chips">
          <i>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg>
            {vehicle.seats}
          </i>
          <i>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
            {vehicle.doors} portes
          </i>
          <i>{vehicle.transmission === 'Automatique' ? 'Auto' : 'Manuelle'}</i>
        </span>
      </div>
      {vehicle.imageCutout
        ? <img class="v-card-cutout" src={vehicle.imageCutout} alt={`${vehicle.name} à louer en Guadeloupe`} loading="lazy" />
        : <img class="v-card-photo" src={vehicle.image} alt={`${vehicle.name} à louer en Guadeloupe`} loading="lazy" />}
      {vehicle.badge && <span class="v-card-badge">{vehicle.badge}</span>}
    </a>
    <div class="v-card-body">
      <span class="v-card-included">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        Kilométrage illimité · assurance incluse
      </span>
      <div class="v-card-quote" data-v-quote>Tarif selon vos dates</div>
      <div class="v-card-actions">
        <a href={`/nos-vehicules/${vehicle.id}`} class="v-card-btn v-card-btn-ghost" data-v-detail>
          Voir le véhicule
        </a>
        <a href={`/reservation?vehicule=${vehicle.id}`} class="v-card-btn v-card-btn-primary" data-v-reserve>
          Réserver
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </div>
</article>

<style>
  .v-card {
    animation-delay: calc(var(--i) * 0.1s);
  }

  .v-card-box {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-normal);
    height: 100%;
    box-shadow: var(--shadow-card);
  }

  .v-card-box:hover {
    transform: translateY(-6px);
    border-color: rgba(227, 24, 55, 0.25);
    box-shadow: var(--shadow-lg);
  }

  /* Visuel studio : voiture détourée sur fond studio premium (DA Sixt) */
  .v-card-visual {
    position: relative;
    display: block;
    aspect-ratio: 16 / 11;
    overflow: hidden;
    background: var(--gradient-studio);
  }

  .v-card-cutout {
    position: absolute;
    left: 6%;
    right: 6%;
    bottom: 5%;
    top: 26%;
    width: 88%;
    height: 69%;
    object-fit: contain;
    object-position: center bottom;
    filter: drop-shadow(0 16px 20px rgba(0, 0, 0, 0.42));
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .v-card-box:hover .v-card-cutout {
    transform: scale(1.045);
  }

  .v-card-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.88;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .v-card-box:hover .v-card-photo {
    transform: scale(1.06);
  }

  .v-card-visual::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 14, 22, 0.82) 0%, rgba(10, 14, 22, 0.18) 38%, transparent 60%);
    pointer-events: none;
  }

  .v-card-visual-head {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 16px 18px;
  }

  .v-card-title {
    display: block;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: white;
    line-height: 1.15;
  }

  .v-card-subtitle {
    display: block;
    font-size: 0.76rem;
    color: rgba(255, 255, 255, 0.75);
    margin-top: 2px;
  }

  .v-card-chips {
    display: flex;
    gap: 6px;
    margin-top: 10px;
  }

  .v-card-chips i {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-style: normal;
    font-size: 0.7rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: var(--radius-full);
    padding: 3px 10px;
  }

  .v-card-badge {
    position: absolute;
    bottom: 14px;
    left: 14px;
    z-index: 2;
    background: var(--gradient-primary);
    color: white;
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: var(--radius-full);
    box-shadow: 0 4px 12px rgba(227, 24, 55, 0.35);
  }

  /* Corps */
  .v-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 14px 18px 18px;
    gap: 10px;
  }

  .v-card-included {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .v-card-included svg {
    color: var(--color-turquoise);
    flex-shrink: 0;
  }

  .v-card-quote {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--color-ink);
  }

  .v-card-quote small {
    display: block;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.76rem;
    color: var(--color-text-muted);
  }

  .v-card-quote s {
    font-weight: 500;
    font-size: 0.82rem;
    color: var(--color-text-subtle);
    margin-left: 6px;
  }

  .v-card-actions {
    display: flex;
    gap: 8px;
    margin-top: auto;
  }

  .v-card-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    flex: 1;
    padding: 11px 10px;
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .v-card-btn-ghost {
    border: 1.5px solid var(--color-border-light);
    color: var(--color-ink);
  }

  .v-card-btn-ghost:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .v-card-btn-primary {
    background: var(--gradient-primary);
    color: white;
    box-shadow: 0 4px 14px rgba(227, 24, 55, 0.25);
  }

  .v-card-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(227, 24, 55, 0.35);
  }
</style>

---
import type { Vehicle } from '../data/data';

export interface Props {
  vehicle: Vehicle;
  index?: number;
}

const { vehicle, index = 0 } = Astro.props;
---

<article class="v-card animate-on-scroll" style={`--i:${index % 4}`}>
  <div class="v-card-box">
    <a href={`/nos-vehicules/${vehicle.id}`} class="v-card-image" data-v-detail aria-label={`Voir la fiche ${vehicle.name}`}>
      <img src={vehicle.image} alt={`${vehicle.name} à louer en Guadeloupe`} loading="lazy" />
      {vehicle.badge && <span class="v-card-badge">{vehicle.badge}</span>}
    </a>
    <div class="v-card-body">
      <div class="v-card-head">
        <div>
          <span class="v-card-category">{vehicle.category}</span>
          <h3 class="v-card-name">
            <a href={`/nos-vehicules/${vehicle.id}`} data-v-detail>{vehicle.name}</a>
          </h3>
        </div>
        <div class="v-card-price">
          <span class="v-card-price-from">dès</span>
          <span class="v-card-price-amount">{vehicle.priceLow}€</span>
          <span class="v-card-price-unit">/jour</span>
        </div>
      </div>
      <div class="v-card-specs">
        <span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg>
          {vehicle.seats} places
        </span>
        <span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          {vehicle.transmission}
        </span>
        <span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
          {vehicle.doors} portes
        </span>
      </div>
      <div class="v-card-actions">
        <a href={`/nos-vehicules/${vehicle.id}`} class="v-card-btn v-card-btn-ghost" data-v-detail>
          Voir le véhicule
        </a>
        <a href={`/reservation?vehicule=${vehicle.id}`} class="v-card-btn v-card-btn-primary" data-v-reserve>
          Réserver
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </div>
</article>

<style>
  .v-card {
    animation-delay: calc(var(--i) * 0.1s);
  }

  .v-card-box {
    display: flex;
    flex-direction: column;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-normal);
    height: 100%;
    box-shadow: var(--shadow-card);
  }

  .v-card-box:hover {
    transform: translateY(-6px);
    border-color: rgba(227, 24, 55, 0.25);
    box-shadow: var(--shadow-lg);
  }

  .v-card-image {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .v-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .v-card-box:hover .v-card-image img {
    transform: scale(1.07);
  }

  .v-card-badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    background: var(--gradient-primary);
    color: white;
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: var(--radius-full);
    box-shadow: 0 4px 12px rgba(227,24,55,0.35);
  }

  .v-card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--spacing-md);
  }

  .v-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 12px;
  }

  .v-card-category {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .v-card-name {
    font-size: 1.1rem;
    margin-top: 2px;
  }

  .v-card-name a {
    color: inherit;
  }

  .v-card-name a:hover {
    color: var(--color-primary);
  }

  .v-card-price {
    display: flex;
    align-items: baseline;
    gap: 3px;
    flex-shrink: 0;
    background: var(--color-rose);
    border-radius: var(--radius-full);
    padding: 6px 14px;
  }

  .v-card-price-from {
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .v-card-price-amount {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-primary);
  }

  .v-card-price-unit {
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .v-card-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: var(--spacing-sm);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .v-card-specs span {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }

  .v-card-specs svg {
    color: var(--color-text-subtle);
  }

  .v-card-actions {
    display: flex;
    gap: 8px;
    margin-top: auto;
  }

  .v-card-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    flex: 1;
    padding: 11px 10px;
    border-radius: var(--radius-full);
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 700;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .v-card-btn-ghost {
    border: 1.5px solid var(--color-border-light);
    color: var(--color-ink);
  }

  .v-card-btn-ghost:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .v-card-btn-primary {
    background: var(--gradient-primary);
    color: white;
    box-shadow: 0 4px 14px rgba(227,24,55,0.25);
  }

  .v-card-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(227,24,55,0.35);
  }
</style>

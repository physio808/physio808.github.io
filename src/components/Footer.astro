---
const footerLinks = {
  vehicules: [
    { href: '/nos-vehicules?categorie=citadine', label: 'Citadines' },
    { href: '/nos-vehicules?categorie=suv', label: 'SUV & 4x4' },
    { href: '/nos-vehicules?categorie=cabriolet', label: 'Cabriolets' },
    { href: '/nos-vehicules?categorie=electrique', label: 'Électriques' },
    { href: '/nos-vehicules?categorie=familial', label: 'Familiaux' },
  ],
  agences: [
    { href: '/nos-agences', label: 'Aéroport Guadeloupe - Maryse Condé' },
    { href: '/nos-agences', label: 'Petit-Canal' },
  ],
  infos: [
    { href: '/a-propos', label: 'À Propos' },
    { href: '/blog', label: 'Blog' },
    { href: '/contact', label: 'Contact' },
    { href: '/faq', label: 'FAQ' },
    { href: '/reservation', label: 'Réserver' },
  ],
  legal: [
    { href: '/conditions', label: 'Conditions de location' },
    { href: '/mentions-legales', label: 'Mentions Légales' },
    { href: '/politique-confidentialite', label: 'Confidentialité' },
  ],
};
---

<footer id="footer">
  <div class="container">
    <!-- Main Footer -->
    <div class="footer-main">
      <!-- Brand -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="/images/adventura-logo-crop.png" alt="Adventura" />
        </a>
        <p class="footer-tagline">
          Location de voiture en Guadeloupe depuis 2019. Kilométrage illimité,
          livraison à l'aéroport Guadeloupe Maryse Condé 24h/24 et zéro frais caché.
        </p>

        <!-- Contact Info -->
        <div class="footer-contact-info">
          <div class="contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.4 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.54a16 16 0 0 0 6.29 6.29l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span>06 90 48 47 76</span>
          </div>
          <div class="contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>Adventurarentals@gmail.com</span>
          </div>
          <div class="contact-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>Aéroport Guadeloupe - Maryse Condé, 97139 Les Abymes</span>
          </div>
        </div>

        <!-- Social links -->
        <div class="social-links">
          <a href="#" class="social-link" aria-label="Facebook">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" class="social-link" aria-label="Instagram">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href="#" class="social-link" aria-label="WhatsApp">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>

      <!-- Links columns -->
      <div class="footer-col">
        <h4 class="footer-col-title">Nos Véhicules</h4>
        <ul class="footer-links">
          {footerLinks.vehicules.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-title">Nos Agences</h4>
        <ul class="footer-links">
          {footerLinks.agences.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-title">Informations</h4>
        <ul class="footer-links">
          {footerLinks.infos.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-title">Newsletter</h4>
        <p class="footer-news-text">Bons plans et itinéraires, une fois par mois.</p>
        <form class="footer-news-form" id="footer-news-form">
          <input type="email" placeholder="Votre email" required aria-label="Votre email" />
          <button type="submit" class="footer-news-btn" aria-label="S'inscrire">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
        <p class="footer-news-ok" id="footer-news-ok" hidden>Merci, inscription confirmée !</p>

        <ul class="footer-links footer-links-legal">
          {footerLinks.legal.map(link => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom-band">
    <div class="container footer-bottom">
      <p class="footer-copyright">
        &copy; {new Date().getFullYear()} Adventura Guadeloupe. Tous droits réservés.
      </p>
      <span class="footer-made">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        Fait avec amour en Guadeloupe
      </span>
    </div>
  </div>
</footer>

<style>
  #footer {
    background: var(--color-bg-soft);
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr 1.2fr;
    gap: var(--spacing-xl);
    padding: var(--spacing-2xl) 0;
  }

  .footer-logo img {
    height: 42px;
    width: auto;
    margin-bottom: var(--spacing-sm);
    transition: transform var(--transition-normal);
  }

  .footer-logo:hover img {
    transform: scale(1.03);
  }

  .footer-tagline {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
    max-width: 300px;
  }

  .footer-contact-info {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: var(--spacing-md);
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 0.84rem;
    color: var(--color-text-muted);
  }

  .contact-item svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-primary);
  }

  .social-links {
    display: flex;
    gap: 10px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: var(--radius-sm);
    background: white;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    transition: all var(--transition-normal);
  }

  .social-link:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
    transform: translateY(-3px);
    box-shadow: 0 8px 18px rgba(143, 29, 46, 0.3);
  }

  .footer-col-title {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 800;
    color: var(--color-ink);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-sm);
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .footer-link {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    transition: all var(--transition-fast);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .footer-link::before {
    content: '→';
    opacity: 0;
    transform: translateX(-8px);
    transition: all var(--transition-fast);
    color: var(--color-primary);
    font-size: 0.8rem;
  }

  .footer-link:hover {
    color: var(--color-primary);
    padding-left: 4px;
  }

  .footer-link:hover::before {
    opacity: 1;
    transform: translateX(0);
  }

  .footer-news-text {
    font-size: 0.82rem;
    margin-bottom: 10px;
  }

  .footer-news-form {
    display: flex;
    gap: 0;
    margin-bottom: var(--spacing-sm);
    border: 1.5px solid var(--color-border-light);
    border-radius: var(--radius-full);
    overflow: hidden;
    background: white;
    transition: border-color var(--transition-fast);
  }

  .footer-news-form:focus-within {
    border-color: var(--color-primary);
  }

  .footer-news-form input {
    flex: 1;
    min-width: 0;
    border: none;
    outline: none;
    padding: 11px 16px;
    font-size: 0.85rem;
    font-family: var(--font-body);
    color: var(--color-ink);
    background: transparent;
  }

  .footer-news-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    border: none;
    background: var(--gradient-primary);
    color: white;
    cursor: pointer;
    transition: filter var(--transition-fast);
  }

  .footer-news-btn:hover {
    filter: brightness(1.1);
  }

  .footer-news-ok {
    font-size: 0.8rem;
    color: var(--color-turquoise);
    margin-bottom: var(--spacing-sm);
  }

  .footer-links-legal {
    margin-top: var(--spacing-md);
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom-band {
    background: white;
    border-top: 1px solid var(--color-border);
  }

  .footer-bottom {
    padding: var(--spacing-sm) var(--spacing-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .footer-copyright {
    font-size: 0.82rem;
    color: var(--color-text-subtle);
  }

  .footer-made {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    color: var(--color-text-subtle);
  }

  .footer-made svg {
    color: var(--color-primary);
  }

  @media (max-width: 1024px) {
    .footer-main {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  const newsForm = document.getElementById('footer-news-form');
  const newsOk = document.getElementById('footer-news-ok');
  newsForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (newsOk) newsOk.hidden = false;
    (newsForm as HTMLFormElement).reset();
  });
</script>

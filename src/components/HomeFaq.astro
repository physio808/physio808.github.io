---
import FaqAccordion from './FaqAccordion.astro';
---

<section class="home-faq section section-soft">
  <div class="container home-faq-grid">
    <div class="home-faq-content">
      <div class="section-header animate-on-scroll">
        <span class="section-badge">Questions fréquentes</span>
        <h2 class="section-title">Tout savoir avant <span>de réserver</span></h2>
        <p class="section-subtitle">Documents, assurance, livraison : les réponses aux questions qu'on nous pose le plus.</p>
      </div>
      <FaqAccordion limit={5} />
      <a href="/faq" class="home-faq-more animate-on-scroll">
        Voir toutes les questions
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    <div class="home-faq-visual animate-on-scroll" style="transition-delay:0.15s" aria-hidden="true">
      <div class="home-faq-img-wrap">
        <img src="/images/vehicles/fiat-500.jpg" alt="" loading="lazy" />
      </div>
      <div class="home-faq-chip home-faq-chip-1">
        <i><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></i>
        Confirmation immédiate
      </div>
      <div class="home-faq-chip home-faq-chip-2">
        <i><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></i>
        Assistance 24/7
      </div>
    </div>
  </div>
</section>

<style>
  .home-faq-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--spacing-2xl);
    align-items: center;
  }

  .home-faq-more {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: var(--spacing-md);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-primary);
    transition: gap var(--transition-fast);
  }

  .home-faq-more:hover {
    gap: 12px;
  }

  .home-faq-visual {
    position: relative;
  }

  .home-faq-img-wrap {
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4/5;
    box-shadow: var(--shadow-lg);
  }

  .home-faq-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .home-faq-chip {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 8px;
    background: white;
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-md);
    padding: 10px 18px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-ink);
    font-family: var(--font-display);
  }

  .home-faq-chip i {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-turquoise);
    color: white;
    flex-shrink: 0;
  }

  .home-faq-chip-1 {
    top: 8%;
    left: -30px;
    animation: float 7s ease-in-out infinite;
  }

  .home-faq-chip-2 {
    bottom: 10%;
    right: -20px;
    animation: float 9s ease-in-out infinite reverse;
  }

  @media (max-width: 1024px) {
    .home-faq-grid {
      grid-template-columns: 1fr;
    }
    .home-faq-visual {
      display: none;
    }
  }
</style>

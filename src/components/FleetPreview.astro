---
import { categories, vehicles } from '../data/data';
import VehicleCard from './VehicleCard.astro';

const preview = vehicles.slice(0, 8);
---

<section class="fleet section section-soft" id="flotte">
  <div class="container">
    <div class="section-header centered animate-on-scroll">
      <span class="section-badge">Notre flotte</span>
      <h2 class="section-title">Un véhicule pour <span>chaque envie</span></h2>
      <p class="section-subtitle">De la citadine économique au 4x4 d'aventure, tous révisés et désinfectés avant chaque départ.</p>
    </div>

    <div class="fleet-tabs animate-on-scroll" role="tablist">
      {categories.map((c) => (
        <button class="fleet-tab" data-cat={c.id} role="tab" aria-selected={c.id === 'all'}>
          <span>{c.icon}</span> {c.label}
        </button>
      ))}
    </div>

    <div class="fleet-grid" id="fleet-grid">
      {preview.map((v, i) => (
        <div class="fleet-grid-item" data-cat={v.categorySlug}>
          <VehicleCard vehicle={v} index={i} />
        </div>
      ))}
    </div>

    <div class="fleet-more animate-on-scroll">
      <a href="/nos-vehicules" class="btn btn-primary btn-lg">
        Voir toute la flotte
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .fleet-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-bottom: var(--spacing-xl);
  }

  .fleet-tab {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: var(--radius-full);
    background: white;
    border: 1.5px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-normal);
  }

  .fleet-tab:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .fleet-tab[aria-selected="true"] {
    background: var(--gradient-primary);
    border-color: transparent;
    color: white;
    box-shadow: var(--shadow-primary);
  }

  .fleet-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
    max-width: 1080px;
    margin-inline: auto;
  }

  .fleet-grid-item.is-hidden {
    display: none;
  }

  .fleet-more {
    text-align: center;
  }

  @media (max-width: 860px) {
    .fleet-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .fleet-grid { grid-template-columns: 1fr; }
    .fleet-tabs { justify-content: flex-start; overflow-x: auto; flex-wrap: nowrap; padding-bottom: 8px; }
  }
</style>

<script>
  const fleetTabs = document.querySelectorAll('.fleet .fleet-tab');
  const fleetItems = document.querySelectorAll('.fleet .fleet-grid-item');

  fleetTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      fleetTabs.forEach((t) => t.setAttribute('aria-selected', 'false'));
      tab.setAttribute('aria-selected', 'true');
      const cat = tab.getAttribute('data-cat');

      fleetItems.forEach((item) => {
        const match = cat === 'all' || item.getAttribute('data-cat') === cat;
        item.classList.toggle('is-hidden', !match);
      });
    });
  });
</script>

---
const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/nos-vehicules', label: 'Nos Véhicules' },
  { href: '/nos-agences', label: 'Nos Agences' },
  { href: '/blog', label: 'Blog' },
  { href: '/a-propos', label: 'À Propos' },
  { href: '/faq', label: 'FAQ' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;

const isActive = (href: string) =>
  currentPath === href || (href !== '/' && currentPath.startsWith(href));
---

<header id="navbar">
  <!-- Top bar: infos pratiques -->
  <div class="nav-topbar">
    <div class="container nav-topbar-inner">
      <a href="tel:+590690484776" class="nav-topbar-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.4 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.54a16 16 0 0 0 6.29 6.29l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span><strong>Assistance 24/7</strong> 06 90 48 47 76</span>
      </a>

      <a href="/" class="nav-logo" aria-label="Adventura - Accueil">
        <img src="/images/adventura-logo-crop.png" alt="Adventura" class="logo-img" />
      </a>

      <div class="nav-topbar-right">
        <a href="mailto:contact@adventura-guadeloupe.fr" class="nav-topbar-item nav-topbar-mail">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span>contact@adventura-guadeloupe.fr</span>
        </a>
        <!-- Hamburger (mobile) -->
        <button id="menu-toggle" class="hamburger" aria-label="Menu" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Nav band: rouge charte -->
  <div class="nav-band" id="nav-band">
    <nav class="container nav-band-inner" aria-label="Navigation principale">
      <div class="nav-band-links">
        {navLinks.map(link => (
          <a href={link.href} class={`nav-link ${isActive(link.href) ? 'active' : ''}`}>
            {link.label}
          </a>
        ))}
      </div>
      <a href="/reservation" class="nav-band-cta">
        Réserver
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="mobile-menu" role="navigation" aria-label="Navigation mobile">
    <div class="mobile-menu-inner">
      {navLinks.map(link => (
        <a href={link.href} class={`mobile-nav-link ${isActive(link.href) ? 'active' : ''}`}>{link.label}</a>
      ))}
      <a href="/reservation" class="btn btn-primary mobile-cta">
        Réserver maintenant
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="tel:+590690484776" class="mobile-phone">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.4 2 2 0 0 1 3.62 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.54a16 16 0 0 0 6.29 6.29l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Assistance 24/7 — 06 90 48 47 76
      </a>
    </div>
  </div>
</header>

<style>
  #navbar {
    position: relative;
    z-index: 1000;
    background: white;
  }

  /* ===== Top bar ===== */
  .nav-topbar {
    background: white;
    border-bottom: 1px solid var(--color-border);
  }

  .nav-topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 84px;
    gap: var(--spacing-md);
  }

  .nav-topbar-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    flex: 1;
  }

  .nav-topbar-item svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .nav-topbar-item strong {
    color: var(--color-ink);
    font-weight: 700;
  }

  .nav-topbar-mail {
    flex: 0;
    white-space: nowrap;
  }

  .nav-topbar-mail:hover {
    color: var(--color-primary);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-img {
    height: 46px;
    width: auto;
    transition: transform var(--transition-normal);
  }

  .nav-logo:hover .logo-img {
    transform: scale(1.04);
  }

  .nav-topbar-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--spacing-sm);
    flex: 1;
  }

  /* ===== Red nav band ===== */
  .nav-band {
    background: var(--gradient-band);
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 2px 12px rgba(227, 24, 55, 0.25);
  }

  .nav-band-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 64px;
  }

  .nav-band-links {
    display: flex;
    align-items: center;
    height: 100%;
    gap: 4px;
  }

  .nav-band-cta {
    position: absolute;
    right: var(--spacing-lg);
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: white;
    color: var(--color-primary);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.85rem;
    padding: 10px 20px;
    border-radius: var(--radius-full);
    box-shadow: 0 3px 10px rgba(0,0,0,0.15);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .nav-band-cta:hover {
    transform: translateY(calc(-50% - 2px));
    box-shadow: 0 8px 18px rgba(0,0,0,0.2);
  }

  .nav-link {
    position: relative;
    padding: 0 18px;
    height: 100%;
    display: flex;
    align-items: center;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.02em;
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 3px;
    background: white;
    border-radius: 3px 3px 0 0;
    transform: translateX(-50%);
    transition: width var(--transition-normal);
  }

  .nav-link:hover {
    color: white;
    background: rgba(255,255,255,0.08);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 60%;
  }

  .nav-link.active {
    color: white;
    background: rgba(255,255,255,0.1);
  }

  /* ===== Hamburger ===== */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
  }

  .hamburger span {
    display: block;
    width: 100%;
    height: 2.5px;
    background: var(--color-ink);
    border-radius: 2px;
    transition: all var(--transition-normal);
    transform-origin: center;
  }

  .hamburger.active span:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger.active span:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  /* ===== Mobile Menu ===== */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: white;
    padding-top: 84px;
    transform: translateX(100%);
    transition: transform var(--transition-normal);
    z-index: 999;
    overflow-y: auto;
  }

  .mobile-menu.open {
    transform: translateX(0);
  }

  .mobile-menu-inner {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-lg);
    gap: 4px;
  }

  .mobile-nav-link {
    display: block;
    padding: 15px 12px;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-ink);
    border-radius: var(--radius-sm);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-fast), background var(--transition-fast), padding-left var(--transition-fast);
  }

  .mobile-nav-link:hover,
  .mobile-nav-link.active {
    color: var(--color-primary);
    background: var(--color-rose);
    padding-left: 18px;
  }

  .mobile-cta {
    margin-top: var(--spacing-lg);
    justify-content: center;
    font-size: 1rem;
    padding: 16px 32px;
  }

  .mobile-phone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: var(--spacing-sm);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .mobile-phone svg {
    color: var(--color-primary);
  }

  /* ===== Responsive ===== */
  @media (max-width: 1150px) {
    .nav-band-cta {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .nav-band {
      display: none;
    }

    .nav-topbar {
      position: sticky;
      top: 0;
      z-index: 1000;
      box-shadow: var(--shadow-sm);
    }

    .nav-topbar-inner {
      height: 64px;
    }

    .nav-topbar-item span {
      display: none;
    }

    .nav-topbar-item {
      flex: 0;
    }

    .nav-logo {
      flex: 1;
      justify-content: flex-start;
    }

    .logo-img {
      height: 38px;
    }

    .nav-topbar-mail {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .nav-topbar-right {
      flex: 0;
    }
  }
</style>

---
---

<section class="promo section-sm">
  <div class="container">
    <div class="promo-box animate-on-scroll">
      <div class="promo-content">
        <span class="badge badge-gold">Offre limitée</span>
        <h2 class="promo-title">-20% sur les locations de 7 jours ou plus</h2>
        <p class="promo-text">Réservez votre séjour dès maintenant et profitez d'une remise immédiate sur toute la flotte, appliquée automatiquement au paiement.</p>
        <div class="promo-actions">
          <a href="/reservation" class="btn btn-primary">
            En profiter
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
      <div class="promo-visual" aria-hidden="true">
        <div class="promo-percent">-20<span>%</span></div>
        <div class="promo-ring"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .promo-box {
    position: relative;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    align-items: center;
    background: white;
    border: 1.5px dashed rgba(227,24,55,0.35);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
    overflow: hidden;
    background:
      radial-gradient(ellipse 40% 90% at 95% 50%, rgba(227,24,55,0.06), transparent),
      white;
  }

  .promo-content {
    position: relative;
    z-index: 1;
  }

  .promo-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 800;
    margin: var(--spacing-sm) 0;
    max-width: 520px;
  }

  .promo-text {
    max-width: 480px;
    margin-bottom: var(--spacing-md);
  }

  .promo-actions {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .promo-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-height: clamp(150px, 24vw, 220px);
  }

  .promo-percent {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 8vw, 5.5rem);
    font-weight: 800;
    color: var(--color-primary);
    position: relative;
    z-index: 1;
    line-height: 1;
  }

  .promo-percent span {
    font-size: 0.52em;
  }

  .promo-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(230px, 56vw, 100%);
    aspect-ratio: 1;
    margin: 0;
    transform: translate(-50%, -50%);
    border: 2px dashed rgba(227,24,55,0.3);
    border-radius: 50%;
    animation: promo-spin 22s linear infinite;
    will-change: transform;
  }

  .promo-ring::before {
    content: '';
    position: absolute;
    inset: 10%;
    border: 2px dashed rgba(232,164,19,0.35);
    border-radius: 50%;
  }

  @keyframes promo-spin {
    from { transform: translate(-50%, -50%) rotate(0deg); }
    to { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .promo-ring {
      animation: none;
    }
  }

  @media (max-width: 900px) {
    .promo-box {
      grid-template-columns: 1fr;
      text-align: center;
      padding: var(--spacing-xl) var(--spacing-md);
    }
    .promo-title, .promo-text { max-width: 100%; }
    .promo-actions { justify-content: center; }
    .promo-visual { margin-top: var(--spacing-md); }
  }
</style>
